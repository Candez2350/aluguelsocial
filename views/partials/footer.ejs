      </main> <!-- Final app-content -->
    </div> <!-- Final app-main -->
  </div> <!-- Final layout-container -->

  <script>
    // 1. Atualizar Data do Sistema Dinamicamente no Cabeçalho
    function atualizarDataSistema() {
      const el = document.getElementById('current-system-date');
      if (el) {
        const opcoes = { 
          weekday: 'long', 
          year: 'numeric', 
          month: 'long', 
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        };
        el.textContent = new Date().toLocaleDateString('pt-BR', opcoes);
      }
    }
    
    atualizarDataSistema();
    setInterval(atualizarDataSistema, 60000);

    // 2. Funcionalidade Global para ocultar/exibir dados sensíveis (Segurança Visual da Vítima)
    window.toggleSigilo = function(btn) {
      const wrapper = btn.closest('.confidential-wrapper');
      if (!wrapper) return;
      
      const dataEl = wrapper.querySelector('.confidential-data');
      if (!dataEl) return;
      
      const isBlurred = dataEl.classList.contains('blurred');
      if (isBlurred) {
        dataEl.classList.remove('blurred');
        btn.innerHTML = `
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
          Ocultar
        `;
      } else {
        dataEl.classList.add('blurred');
        btn.innerHTML = `
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
          Exibir
        `;
      }
    };
  </script>
</body>
</html>
