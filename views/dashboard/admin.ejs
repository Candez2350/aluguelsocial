<%- include('../partials/header') %>

  <!-- Mensagens de Alerta Globais -->
  <div id="admin-alert-container" class="mb-6"></div>

  <!-- Top Métricas do Administrador -->
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
    <!-- Card Custo Individual -->
    <div
      class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm flex justify-between items-start">
      <div>
        <div class="text-gov-700 font-display font-bold uppercase tracking-wider text-xs mb-1">Benefício Base</div>
        <div class="text-gov-900 font-display font-bold text-3xl leading-none" id="val-base-display">
          R$ <%= valorBase.toFixed(2) %>
        </div>
        <span class="text-slate-500 text-xs mt-2 block font-medium">Valor de repasse por cidadã</span>
      </div>
      <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-200 flex items-center justify-center text-slate-500 shadow-inner">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
      </div>
    </div>

    <!-- Card Total Processos -->
    <div
      class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm flex justify-between items-start">
      <div>
        <div class="text-slate-700 font-display font-bold uppercase tracking-wider text-xs mb-1">Total Registros</div>
        <div class="text-slate-900 font-display font-bold text-3xl leading-none">
          <%= estatisticas.total %>
        </div>
        <span class="text-slate-500 text-xs mt-2 block font-medium">Processos ativos e julgados</span>
      </div>
      <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-200 flex items-center justify-center text-slate-500 shadow-inner">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
      </div>
    </div>

    <!-- Card Aprovados -->
    <div
      class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm flex justify-between items-start">
      <div>
        <div class="text-emerald-700 font-display font-bold uppercase tracking-wider text-xs mb-1">Aprovados</div>
        <div class="text-emerald-900 font-display font-bold text-3xl leading-none">
          <%= estatisticas.aprovado %>
        </div>
        <span class="text-slate-500 text-xs mt-2 block font-medium">Habilitados na triagem/SLA</span>
      </div>
      <div class="w-12 h-12 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center text-emerald-500 shadow-inner">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </div>
    </div>

    <!-- Card Indeferidos -->
    <div
      class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm flex justify-between items-start">
      <div>
        <div class="text-rose-700 font-display font-bold uppercase tracking-wider text-xs mb-1">Indeferidos</div>
        <div class="text-rose-900 font-display font-bold text-3xl leading-none">
          <%= estatisticas.indeferido %>
        </div>
        <span class="text-slate-500 text-xs mt-2 block font-medium">Requisitos não atendidos</span>
      </div>
      <div class="w-12 h-12 rounded-xl bg-rose-50 border border-rose-100 flex items-center justify-center text-rose-500 shadow-inner">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </div>
    </div>
  </div>

  <!-- ================= ABA 1: CONTROLE DE PROCESSOS GERAL ================= -->
  <% if (activeRoute === 'processos') { %>
  <div id="tab-content-processos" class="tab-panel-content block">
    <!-- Barra de Pesquisa e Filtros Administrativos -->
    <div class="flex flex-col md:flex-row gap-4 mb-6">
      <div class="relative flex-grow min-w-[280px]">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </div>
        <input type="text" id="busca-processos"
          class="w-full bg-white border-1.5 border-slate-200 text-slate-900 text-sm rounded-xl pl-10 pr-4 py-3 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm"
          placeholder="Buscar por Processo SEI, Cidadã ou CPF..." onkeyup="filtrarProcessosAdmin()">
      </div>

      <div class="flex items-center gap-2">
        <label for="filtro-status-admin"
          class="text-xs font-bold text-slate-500 uppercase tracking-wider">Status:</label>
        <select id="filtro-status-admin"
          class="bg-white border-1.5 border-slate-200 text-slate-700 text-sm font-semibold rounded-xl px-4 py-3 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm appearance-none pr-10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2220%22%20height%3D%2220%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:1em] bg-no-repeat bg-[position:right_1rem_center]"
          onchange="filtrarProcessosAdmin()">
          <option value="TODOS" selected>TODOS</option>
          <option value="RASCUNHO">RASCUNHO</option>
          <option value="TRIAGEM">TRIAGEM</option>
          <option value="ANALISE">ANÁLISE</option>
          <option value="APROVADO">APROVADO</option>
          <option value="APTO_PAGAMENTO">APTO PAGAMENTO</option>
          <option value="RECURSO">RECURSO</option>
          <option value="INDEFERIDO">INDEFERIDO</option>
          <option value="SUSPENSO">SUSPENSO</option>
          <option value="ENCERRADO">ENCERRADO</option>
        </select>
      </div>

      <div class="flex items-center gap-2">
        <label for="filtro-esteira-admin"
          class="text-xs font-bold text-slate-500 uppercase tracking-wider">Esteira:</label>
        <select id="filtro-esteira-admin"
          class="bg-white border-1.5 border-slate-200 text-slate-700 text-sm font-semibold rounded-xl px-4 py-3 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm appearance-none pr-10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2220%22%20height%3D%2220%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:1em] bg-no-repeat bg-[position:right_1rem_center]"
          onchange="filtrarProcessosAdmin()">
          <option value="TODAS" selected>TODAS</option>
          <option value="SIMPLIFICADO">SIMPLIFICADO</option>
          <option value="COMUM">COMUM</option>
        </select>
      </div>
    </div>

    <!-- Tabela de Controle Geral -->
    <div class="bg-white border border-slate-200 shadow-sm rounded-2xl overflow-hidden mb-8">
      <div class="px-6 py-5 border-b border-slate-100 flex items-center bg-slate-50/50">
        <h2 class="text-gov-900 font-display font-bold text-lg flex items-center gap-2">
          <svg class="w-5 h-5 text-gov-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10">
            </path>
          </svg>
          Todos os Processos Cadastrados no Sistema
        </h2>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse" id="tabela-processos-admin">
          <thead>
            <tr
              class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider font-bold border-b-2 border-slate-200">
              <th class="px-6 py-4">Processo SEI</th>
              <th class="px-6 py-4">Cidadã (CPF)</th>
              <th class="px-6 py-4">Esteira</th>
              <th class="px-6 py-4">Renda P.C.</th>
              <th class="px-6 py-4">Status Atual</th>
              <th class="px-6 py-4">Ações Rápidas</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (processos.length===0) { %>
              <tr class="sem-processos-row">
                <td colspan="6" class="text-center text-slate-500 py-12">Nenhum processo tramitando no sistema de
                  auxílio.</td>
              </tr>
              <% } else { %>
                <% processos.forEach(p=> { %>
                  <tr class="admin-processo-row group hover:bg-slate-50 cursor-pointer transition-colors"
                    data-id="<%= p.id %>" data-sei="<%= p.numeroProcessoSei %>" data-nome="<%= p.beneficiaria.nome %>"
                    data-cpf="<%= p.beneficiaria.cpf %>" data-status="<%= p.statusAtual %>"
                    data-esteira="<%= p.tipoEsteira %>" onclick="abrirDrawerAdminFicha('<%= p.id %>')">
                    <td class="px-6 py-4 whitespace-nowrap font-semibold text-slate-900">
                      <%= p.numeroProcessoSei %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap" onclick="event.stopPropagation();">
                      <div class="flex items-center gap-2">
                        <span class="confidential-data blur-[5px] select-none text-slate-700 font-medium">
                          <%= p.beneficiaria.nome %> (<%= p.beneficiaria.cpf %>)
                        </span>
                        <button
                          class="text-gov-500 hover:text-gov-700 hover:bg-gov-50 text-[11px] font-bold px-2 py-1 rounded transition-colors flex items-center gap-1 btn-toggle-sigilo"
                          onclick="toggleSigilo(this)" title="Exibir/Ocultar Dados">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                          </svg> Exibir
                        </button>
                      </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span
                        class="px-2.5 py-1 rounded-md text-xs font-bold uppercase tracking-wider border <%= p.tipoEsteira === 'SIMPLIFICADO' ? 'bg-amber-50 text-amber-600 border-amber-200' : 'bg-blue-50 text-blue-600 border-blue-200' %>">
                        <%= p.tipoEsteira %>
                      </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-slate-700">R$ <%=
                        p.beneficiaria.rendaPerCapitaDigitada.toFixed(2) %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <% let stClass="bg-slate-100 text-slate-600 border-slate-200" ; if(p.statusAtual==='TRIAGEM' )
                        stClass="bg-blue-50 text-blue-600 border-blue-200" ; else if(p.statusAtual==='ANALISE' )
                        stClass="bg-amber-50 text-amber-600 border-amber-200" ; else if(p.statusAtual==='APROVADO' )
                        stClass="bg-emerald-50 text-emerald-600 border-emerald-200" ; else
                        if(p.statusAtual==='APTO_PAGAMENTO' ) stClass="bg-indigo-50 text-indigo-600 border-indigo-200" ;
                        else if(p.statusAtual==='INDEFERIDO' ) stClass="bg-red-50 text-red-600 border-red-200" ; %>
                        <span
                          class="px-2.5 py-1 rounded-md text-[11px] font-bold uppercase tracking-wider border <%= stClass %>">
                          <%= p.statusAtual.replace('_', ' ' ) %>
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap" onclick="event.stopPropagation();">
                      <div class="flex gap-2">
                        <% if (p.statusAtual !=='SUSPENSO' ) { %>
                          <button
                            class="px-2 py-1.5 text-[11px] font-bold rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition-colors"
                            onclick="alterarStatusAdmin('<%= p.id %>', 'SUSPENSO')" title="Suspender Benefício">
                            Susp.</button>
                          <% } else { %>
                            <button
                              class="px-2 py-1.5 text-[11px] font-bold rounded-lg border border-blue-200 text-blue-600 hover:bg-blue-50 transition-colors"
                              onclick="alterarStatusAdmin('<%= p.id %>', 'TRIAGEM')" title="Reativar Processo">
                              Reat.</button>
                            <% } %>
                              <% if (p.statusAtual !=='ENCERRADO' ) { %>
                                <button
                                  class="px-2 py-1.5 text-[11px] font-bold rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-100 transition-colors"
                                  onclick="alterarStatusAdmin('<%= p.id %>', 'ENCERRADO')" title="Encerrar Processo">
                                  Encerrar</button>
                                <% } %>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                    <% } %>
          </tbody>
        </table>
      </div>

      <!-- Paginação -->
      <div
        class="px-6 py-4 border-t border-slate-100 bg-slate-50/50 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3 text-sm text-slate-600 font-medium">
          <span>Itens por página:</span>
          <select id="limit-tabela-processos-admin"
            class="bg-white border border-slate-200 rounded-lg px-2 py-1 text-slate-700 outline-none focus:border-gov-500"
            onchange="alterarLimiteProcessos()">
            <option value="5" selected>5</option>
            <option value="10">10</option>
            <option value="15">15</option>
          </select>
        </div>
        <div id="info-tabela-processos-admin" class="text-sm text-slate-500 font-medium">
          Exibindo 1 a 5 de 15 registros
        </div>
        <div class="flex items-center gap-2">
          <button id="btn-prev-tabela-processos-admin"
            class="px-3 py-1.5 border border-slate-200 bg-white text-slate-700 font-semibold text-sm rounded-lg hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
            onclick="pagProcessosAnt()">Ant.</button>
          <button id="btn-next-tabela-processos-admin"
            class="px-3 py-1.5 border border-slate-200 bg-white text-slate-700 font-semibold text-sm rounded-lg hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
            onclick="pagProcessosProx()">Próx.</button>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ================= ABA 2: GESTÃO DE OPERADORES ================= -->
  <% if (activeRoute === 'usuarios') { %>
  <div id="tab-content-usuarios" class="tab-panel-content block">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
      <!-- Bloco da Esquerda -->
      <div class="bg-white border border-slate-200 shadow-sm rounded-2xl overflow-hidden self-start">
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50">
          <h2 class="text-gov-900 font-display font-bold text-lg flex items-center gap-2">Cadastrar Novo Operador</h2>
        </div>
        <div class="p-6">
          <form onsubmit="cadastrarUsuario(event)">
            <div class="mb-5">
              <label for="usr-nome" class="block text-slate-700 font-semibold text-xs mb-2 tracking-wide uppercase">Nome
                Completo</label>
              <input type="text" id="usr-nome"
                class="w-full bg-surface-50 border-1.5 border-slate-200 text-slate-900 px-4 py-3 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:bg-white focus:ring-4 focus:ring-gov-500/10 transition-all"
                required placeholder="ex: Maria das Dores">
            </div>
            <div class="mb-5">
              <label for="usr-email"
                class="block text-slate-700 font-semibold text-xs mb-2 tracking-wide uppercase">E-mail
                Institucional</label>
              <input type="email" id="usr-email"
                class="w-full bg-surface-50 border-1.5 border-slate-200 text-slate-900 px-4 py-3 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:bg-white focus:ring-4 focus:ring-gov-500/10 transition-all"
                required placeholder="ex: maria@aluguel.gov.br">
            </div>
            <div class="mb-5">
              <label for="usr-senha"
                class="block text-slate-700 font-semibold text-xs mb-2 tracking-wide uppercase">Senha de Acesso</label>
              <input type="password" id="usr-senha"
                class="w-full bg-surface-50 border-1.5 border-slate-200 text-slate-900 px-4 py-3 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:bg-white focus:ring-4 focus:ring-gov-500/10 transition-all"
                required placeholder="Mínimo 6 caracteres" minlength="6">
            </div>
            <div class="mb-8">
              <label for="usr-role"
                class="block text-slate-700 font-semibold text-xs mb-2 tracking-wide uppercase">Perfil de Acesso
                (Role)</label>
              <select id="usr-role"
                class="w-full bg-surface-50 border-1.5 border-slate-200 text-slate-900 px-4 py-3 rounded-xl text-sm font-medium focus:outline-none focus:border-gov-500 focus:bg-white focus:ring-4 focus:ring-gov-500/10 transition-all appearance-none pr-10 bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20width%3D%2220%22%20height%3D%2220%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2364748b%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-[length:1em] bg-no-repeat bg-[position:right_1rem_center]"
                required>
                <option value="OPERADOR_ENTRADA" selected>OPERADOR ENTRADA (Triagem)</option>
                <option value="ANALISTA_SEDSODH">ANALISTA SEDSODH (Judicial)</option>
                <option value="ASSISTENTE_SOCIAL_SUAS">ASSISTENTE SOCIAL SUAS (Comum)</option>
                <option value="GESTOR_SEMPI">GESTOR SEMPI (Dashboard)</option>
                <option value="ADMIN">ADMINISTRADOR (Total)</option>
              </select>
            </div>
            <button type="submit" class="btn-primary w-full py-3.5 text-sm uppercase tracking-wide">Criar Novo
              Operador</button>
          </form>
        </div>
      </div>

      <!-- Bloco da Direita -->
      <div class="bg-white border border-slate-200 shadow-sm rounded-2xl overflow-hidden self-start">
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50">
          <h2 class="text-gov-900 font-display font-bold text-lg flex items-center gap-2">Usuários Credenciados Ativos</h2>
        </div>
        <div class="p-6">
          <div id="grid-usuarios" class="flex flex-col gap-4">
            <p class="text-slate-500 text-center text-sm font-medium">Carregando usuários cadastrados...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ================= ABA 3: PARÂMETROS DO BENEFÍCIO ================= -->
  <% if (activeRoute === 'parametros') { %>
  <div id="tab-content-parametros" class="tab-panel-content block">
    <div class="bg-white border border-slate-200 shadow-sm rounded-2xl overflow-hidden mb-8">
      <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50">
        <h2 class="text-gov-900 font-display font-bold text-lg flex items-center gap-2">Configurações Gerais e Valores da Folha</h2>
      </div>
      <div class="p-8">
        <p class="text-slate-500 leading-relaxed mb-8 max-w-3xl text-sm font-medium">
          A alteração do <strong class="text-slate-700">Valor Base do Auxílio</strong> afeta diretamente todas as
          projeções da folha e estimativas orçamentárias geradas no dashboard estratégico da SEMPI. Certifique-se de que
          a alteração está respaldada por decreto.
        </p>

        <form id="form-valor-base" onsubmit="atualizarValorBase(event)"
          class="flex flex-col sm:flex-row gap-4 items-end max-w-xl bg-slate-50 border border-slate-200 p-6 rounded-2xl">
          <div class="flex-grow w-full">
            <label for="valor-base" class="block font-bold text-gov-700 text-xs mb-2 uppercase tracking-wide">Valor do
              Repasse (R$)</label>
            <input type="number" step="0.01" min="0" id="valor-base"
              class="w-full bg-white border-1.5 border-slate-300 text-gov-900 font-bold text-lg px-4 py-3 rounded-xl focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all"
              value="<%= valorBase %>" required>
          </div>
          <button type="submit"
            class="btn-primary py-3.5 px-8 whitespace-nowrap text-sm font-bold w-full sm:w-auto h-[52px]">
            Salvar Parâmetro
          </button>
        </form>

        <div class="mt-10 pt-8 border-t border-dashed border-slate-200 max-w-3xl">
          <h3 class="font-display font-bold text-gov-900 text-base mb-4 flex items-center gap-2">Observações de Governança</h3>
          <ul class="flex flex-col gap-3 text-slate-500 text-sm font-medium">
            <li class="flex items-start gap-2"><span class="text-amber-500">▪</span> Qualquer alteração é registrada
              para fins de auditoria no log.</li>
            <li class="flex items-start gap-2"><span class="text-amber-500">▪</span> Processos já encerrados não sofrem
              recálculo retroativo.</li>
            <li class="flex items-start gap-2"><span class="text-amber-500">▪</span> A modificação se propaga para
              novos requerimentos e folhas subsequentes.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ================= GAVETA LATERAL DE OVERRIDES DO ADMIN ================= -->
  <div id="drawer-overlay"
    class="fixed inset-0 bg-gov-900/40 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"
    onclick="fecharDrawerAdmin()"></div>
  <div id="ficha-drawer-admin"
    class="fixed top-0 right-0 h-full w-full max-w-lg bg-white shadow-[-10px_0_40px_rgba(0,0,0,0.1)] z-50 transform translate-x-full transition-transform duration-300 flex flex-col">
    <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-gov-50/50">
      <h3 class="font-display font-bold text-gov-900 text-lg" id="drawer-header-title-admin">Processo Administrativo
      </h3>
      <button onclick="fecharDrawerAdmin()"
        class="text-slate-400 hover:text-red-500 transition-colors p-1 rounded-md hover:bg-red-50">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="flex-grow overflow-y-auto p-6 flex flex-col gap-8" id="drawer-ficha-content-admin">
      <!-- Renderizado dinamicamente via JS -->
    </div>

    <div class="p-6 bg-gov-50 border-t border-gov-100 flex flex-col gap-4">
      <div
        class="text-xs font-bold text-gov-700 uppercase tracking-wide border-b border-gov-200 pb-2 flex items-center gap-1.5">
        Painel de Intervenção Administrativa
      </div>
      <div class="flex gap-2 justify-end" id="drawer-admin-action-row">
        <!-- Populados dinamicamente via JS -->
      </div>
    </div>
  </div>

  <!-- Dados brutos serializados no cliente -->
  <textarea id="processos-raw-data-admin" class="hidden"><%- JSON.stringify(processos) %></textarea>

  <script>
    // Serialização do banco
    const dbProcessosAdmin = JSON.parse(document.getElementById('processos-raw-data-admin').value);

    // Estado local de paginação
    const adminProcessosPag = { pag: 1, limit: 5 };

    document.addEventListener('DOMContentLoaded', () => {
      carregarUsuarios();
      inicializarAtributosTabelaAdmin();
      aplicarPaginacaoProcessosAdmin();
    });

    function switchAdminTab(tabName, clickedBtn) {
      document.querySelectorAll('.tab-panel-content').forEach(panel => {
        panel.classList.add('hidden');
        panel.classList.remove('block');
      });

      document.querySelectorAll('button[id^="tab-btn-"]').forEach(btn => {
        btn.className = "px-5 py-2.5 rounded-lg font-semibold text-sm transition-all duration-200 text-slate-500 hover:text-slate-700 hover:bg-slate-200/50";
      });

      document.getElementById(`tab-content-${tabName}`).classList.remove('hidden');
      document.getElementById(`tab-content-${tabName}`).classList.add('block');

      clickedBtn.className = "px-5 py-2.5 rounded-lg font-semibold text-sm transition-all duration-200 bg-white text-gov-900 shadow-sm ring-1 ring-slate-900/5";
    }

    function inicializarAtributosTabelaAdmin() {
      document.querySelectorAll('#tabela-processos-admin .admin-processo-row').forEach(row => {
        row.setAttribute('data-filtered-out', 'false');
      });
    }

    // --- FILTRAR E BUSCAR PROCESSOS ---
    function filtrarProcessosAdmin() {
      const q = document.getElementById('busca-processos').value.toLowerCase().trim();
      const status = document.getElementById('filtro-status-admin').value;
      const esteira = document.getElementById('filtro-esteira-admin').value;

      const rows = document.querySelectorAll('#tabela-processos-admin .admin-processo-row');
      rows.forEach(row => {
        const sei = row.getAttribute('data-sei').toLowerCase();
        const nome = row.getAttribute('data-nome').toLowerCase();
        const cpf = row.getAttribute('data-cpf').toLowerCase();
        const rowStatus = row.getAttribute('data-status');
        const rowEsteira = row.getAttribute('data-esteira');

        const matchText = sei.includes(q) || nome.includes(q) || cpf.includes(q);
        const matchStatus = status === 'TODOS' || rowStatus === status;
        const matchEsteira = esteira === 'TODAS' || rowEsteira === esteira;

        if (matchText && matchStatus && matchEsteira) {
          row.setAttribute('data-filtered-out', 'false');
        } else {
          row.setAttribute('data-filtered-out', 'true');
        }
      });

      adminProcessosPag.pag = 1;
      aplicarPaginacaoProcessosAdmin();
    }

    function aplicarPaginacaoProcessosAdmin() {
      const tableId = 'tabela-processos-admin';
      const rows = Array.from(document.querySelectorAll(`#${tableId} .admin-processo-row`));
      const filteredRows = rows.filter(row => row.getAttribute('data-filtered-out') !== 'true');

      const total = filteredRows.length;
      const limit = adminProcessosPag.limit;
      const totalPages = Math.max(1, Math.ceil(total / limit));

      if (adminProcessosPag.pag > totalPages) adminProcessosPag.pag = totalPages;
      if (adminProcessosPag.pag < 1) adminProcessosPag.pag = 1;

      const start = (adminProcessosPag.pag - 1) * limit;
      const end = Math.min(start + limit, total);

      rows.forEach(row => row.style.display = 'none');
      filteredRows.slice(start, end).forEach(row => row.style.display = '');

      const info = document.getElementById(`info-${tableId}`);
      if (info) {
        info.textContent = total === 0 ? 'Nenhum processo encontrado' : `Exibindo ${start + 1}-${end} de ${total} registros`;
      }

      document.getElementById(`btn-prev-${tableId}`).disabled = adminProcessosPag.pag === 1;
      document.getElementById(`btn-next-${tableId}`).disabled = adminProcessosPag.pag === totalPages;
    }

    function pagProcessosAnt() {
      if (adminProcessosPag.pag > 1) {
        adminProcessosPag.pag--;
        aplicarPaginacaoProcessosAdmin();
      }
    }

    function pagProcessosProx() {
      const rows = Array.from(document.querySelectorAll('#tabela-processos-admin .admin-processo-row'));
      const filteredRows = rows.filter(row => row.getAttribute('data-filtered-out') !== 'true');
      const totalPages = Math.ceil(filteredRows.length / adminProcessosPag.limit);
      if (adminProcessosPag.pag < totalPages) {
        adminProcessosPag.pag++;
        aplicarPaginacaoProcessosAdmin();
      }
    }

    function alterarLimiteProcessos() {
      adminProcessosPag.limit = parseInt(document.getElementById('limit-tabela-processos-admin').value, 10);
      adminProcessosPag.pag = 1;
      aplicarPaginacaoProcessosAdmin();
    }

    // --- CARREGAR USUÁRIOS EM GRID PREMIUM ---
    async function carregarUsuarios() {
      try {
        const response = await fetch('/api/config/usuarios');
        const usuarios = await response.json();

        const grid = document.getElementById('grid-usuarios');
        grid.innerHTML = '';

        if (usuarios.length === 0) {
          grid.innerHTML = '<p class="text-slate-500 text-center text-sm font-medium">Nenhum operador credenciado.</p>';
          return;
        }

        usuarios.forEach(u => {
          const firstLetter = u.nome.trim().substring(0, 1).toUpperCase();

          let roleBadgeClass = 'bg-blue-50 text-blue-600 border-blue-200';
          if (u.role === 'ADMIN') roleBadgeClass = 'bg-red-50 text-red-600 border-red-200';
          else if (u.role === 'GESTOR_SEMPI') roleBadgeClass = 'bg-orange-50 text-orange-600 border-orange-200';
          else if (u.role === 'ASSISTENTE_SOCIAL_SUAS') roleBadgeClass = 'bg-emerald-50 text-emerald-600 border-emerald-200';

          const userCard = document.createElement('div');
          userCard.className = "flex items-center justify-between gap-4 p-4 rounded-xl border border-slate-200 bg-white hover:border-gov-300 transition-colors shadow-sm";

          userCard.innerHTML = `
          <div class="flex items-center gap-4 min-w-0">
            <div class="w-11 h-11 rounded-full bg-gov-100 text-gov-700 font-display font-bold text-lg flex items-center justify-center shrink-0">
              ${firstLetter}
            </div>
            <div class="min-w-0">
              <strong class="block text-sm text-slate-900 truncate">${u.nome}</strong>
              <span class="block text-xs text-slate-500 truncate mt-0.5">${u.email}</span>
              <span class="inline-block mt-1.5 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider rounded border ${roleBadgeClass}">
                ${u.role.replace('_', ' ')}
              </span>
            </div>
          </div>
          <button onclick="deletarUsuario('${u.id}')" class="shrink-0 px-3 py-1.5 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition-colors text-xs font-bold flex items-center gap-1.5" title="Remover Operador">
            Excluir
          </button>
        `;
          grid.appendChild(userCard);
        });
      } catch (error) {
        console.error('Erro ao carregar usuários:', error);
      }
    }

    async function cadastrarUsuario(e) {
      e.preventDefault();
      const nome = document.getElementById('usr-nome').value;
      const email = document.getElementById('usr-email').value;
      const senha = document.getElementById('usr-senha').value;
      const role = document.getElementById('usr-role').value;

      try {
        const response = await fetch('/api/config/usuarios', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nome, email, senha, role })
        });

        const res = await response.json();

        if (res.success) {
          mostrarAlerta('success', res.message);
          e.target.reset();
          carregarUsuarios();
        } else {
          mostrarAlerta('danger', res.error);
        }
      } catch (error) {
        mostrarAlerta('danger', 'Erro de rede ao cadastrar operador.');
      }
    }

    async function deletarUsuario(id) {
      if (!confirm('Deseja realmente remover este operador do sistema?')) return;

      try {
        const response = await fetch(`/api/config/usuarios/${id}`, { method: 'DELETE' });
        const res = await response.json();

        if (res.success) {
          mostrarAlerta('success', res.message);
          carregarUsuarios();
        } else {
          mostrarAlerta('danger', res.error);
        }
      } catch (error) {
        mostrarAlerta('danger', 'Erro ao processar exclusão do operador.');
      }
    }

    async function atualizarValorBase(e) {
      e.preventDefault();
      const valor = document.getElementById('valor-base').value;

      try {
        const response = await fetch('/api/config/valor', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ valor })
        });

        const res = await response.json();

        if (res.success) {
          mostrarAlerta('success', res.message);
          document.getElementById('val-base-display').innerHTML = `R$ ${parseFloat(valor).toFixed(2)}`;
        } else {
          mostrarAlerta('danger', res.error);
        }
      } catch (error) {
        mostrarAlerta('danger', 'Erro ao salvar valor do benefício.');
      }
    }

    async function alterarStatusAdmin(id, status) {
      try {
        const response = await fetch(`/api/processos/${id}/status`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ status })
        });

        const res = await response.json();
        if (res.success) {
          window.location.reload();
        } else {
          mostrarAlerta('danger', res.error);
        }
      } catch (error) {
        mostrarAlerta('danger', 'Erro de rede.');
      }
    }

    // --- DRAWER DE DETALHES DO ADMIN (SLIDE-IN + INTERVENÇÕES) ---
    function abrirDrawerAdminFicha(id) {
      const p = dbProcessosAdmin.find(proc => String(proc.id) === String(id));
      if (!p) return;

      document.getElementById('drawer-header-title-admin').textContent = `Processo SEI: ${p.numeroProcessoSei}`;

      let dadosBancarios = { banco: 'Não Cadastrado', agencia: 'N/A', conta: 'N/A' };
      try {
        if (p.beneficiaria.dadosBancariosManuais) {
          dadosBancarios = JSON.parse(p.beneficiaria.dadosBancariosManuais);
        }
      } catch (e) { }

      const content = document.getElementById('drawer-ficha-content-admin');
      content.innerHTML = `
        <!-- Cabeçalho de Status -->
        <div>
          <h4 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-3">Situação Cadastral</h4>
          <div class="flex flex-wrap gap-2 items-center">
            <span class="px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider border ${
              p.statusAtual === 'TRIAGEM' ? 'bg-blue-50 text-blue-600 border-blue-200' :
              p.statusAtual === 'ANALISE' ? 'bg-amber-50 text-amber-600 border-amber-200' :
              p.statusAtual === 'APROVADO' ? 'bg-emerald-50 text-emerald-600 border-emerald-200' :
              p.statusAtual === 'INDEFERIDO' ? 'bg-red-50 text-red-600 border-red-200' :
              p.statusAtual === 'SUSPENSO' ? 'bg-slate-100 text-slate-500 border-slate-200' :
              'bg-indigo-50 text-indigo-600 border-indigo-200'
            }">
              ${p.statusAtual}
            </span>
            <span class="px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider border ${
              p.tipoEsteira === 'SIMPLIFICADO' ? 'bg-amber-50 text-amber-600 border-amber-200' : 'bg-blue-50 text-blue-600 border-blue-200'
            }">
              Esteira ${p.tipoEsteira}
            </span>
            ${p.temMPU ? `
              <span class="px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wider border bg-red-50 text-red-600 border-red-200">
                Prioridade Judicial
              </span>
            ` : ''}
          </div>
        </div>

        <!-- Dados Pessoais -->
        <div>
          <h4 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-3">Perfil da Beneficiária</h4>
          <div class="grid grid-cols-2 gap-4 bg-slate-50 border border-slate-100 rounded-xl p-4">
            <div class="col-span-2">
              <span class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Nome Completo (Protegido)</span>
              <div class="flex items-center gap-2">
                <span class="confidential-data font-bold text-slate-800 text-base blur-[4px] select-none">${p.beneficiaria.nome}</span>
                <button class="text-gov-500 hover:text-gov-700 bg-white border border-slate-200 text-[10px] font-bold px-2 py-1 rounded transition-colors flex items-center gap-1 shadow-sm" onclick="toggleSigilo(this)">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg> Exibir
                </button>
              </div>
            </div>
            
            <div class="col-span-2 sm:col-span-1">
              <span class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">CPF (Protegido)</span>
              <div class="flex items-center gap-2">
                <span class="confidential-data font-mono text-slate-800 text-sm blur-[4px] select-none">${p.beneficiaria.cpf}</span>
                <button class="text-gov-500 hover:text-gov-700 bg-white border border-slate-200 text-[10px] font-bold px-2 py-1 rounded transition-colors flex items-center gap-1 shadow-sm" onclick="toggleSigilo(this)">
                  Exibir
                </button>
              </div>
            </div>

            <div class="col-span-2 sm:col-span-1">
              <span class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">NIS CadÚnico</span>
              <span class="font-semibold text-slate-800 text-sm">${p.beneficiaria.nisCadunico}</span>
            </div>

            <div class="col-span-2 sm:col-span-1">
              <span class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Renda Per Capita</span>
              <span class="font-semibold text-slate-800 text-sm">R$ ${p.beneficiaria.rendaPerCapitaDigitada.toFixed(2)}</span>
            </div>

            <div class="col-span-2 sm:col-span-1">
              <span class="block text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Bairro</span>
              <span class="font-semibold text-slate-800 text-sm">${p.beneficiaria.bairro}</span>
            </div>
          </div>
        </div>

        <!-- Ficha de Conta Bancária -->
        <div>
          <h4 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-3">Conta para Depósito</h4>
          <div class="bg-gradient-to-br from-slate-700 to-slate-900 rounded-2xl p-5 text-white shadow-lg relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-32 h-32 rounded-full bg-white/5 blur-2xl"></div>
            <div class="flex justify-between items-center mb-6 relative z-10">
              <div class="w-10 h-8 rounded bg-yellow-400/80 border border-yellow-300/50 flex items-center justify-center opacity-80">
                <div class="w-6 h-4 border border-yellow-600/30 rounded-sm"></div>
              </div>
              <div class="font-display font-bold tracking-widest text-white/50 text-xs">ALUGUEL SOCIAL</div>
            </div>
            <div class="font-mono text-xl tracking-widest mb-6 relative z-10 text-white/90">
              AG: ${dadosBancarios.agencia} | CC: ${dadosBancarios.conta}
            </div>
            <div class="flex justify-between items-end relative z-10">
              <div>
                <div class="text-[9px] uppercase tracking-wider text-white/50 mb-1">Favorecida</div>
                <div class="font-bold text-sm tracking-wide">${p.beneficiaria.nome.toUpperCase()}</div>
              </div>
              <div class="text-right">
                <div class="text-[9px] uppercase tracking-wider text-white/50 mb-1">Banco</div>
                <div class="font-bold text-xs">${dadosBancarios.banco}</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Checklist de Análise de Documentos -->
        <div>
          <h4 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-3">Triagem de Documentos</h4>
          <div class="flex flex-col gap-3">
            ${p.documentos && p.documentos.length > 0 ? p.documentos.map(doc => {
              const verificado = doc.verificadoManualmente;
              return `
                <div class="flex items-center justify-between p-3 bg-white border border-slate-200 rounded-xl shadow-sm">
                  <span class="font-semibold text-slate-700 text-sm">${doc.tipoDocumento}</span>
                  <span class="px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider ${verificado ? 'bg-emerald-50 text-emerald-600' : 'bg-slate-100 text-slate-500'}">
                    ${verificado ? 'Verificado' : 'Pendente'}
                  </span>
                </div>
              `;
            }).join('') : '<p class="text-slate-500 text-sm italic">Nenhum documento anexado.</p>'}
          </div>
        </div>

        <!-- Pareceres Sociais e Técnicos -->
        <div>
          <h4 class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-3">Parecer Técnico (SUAS)</h4>
          <div class="bg-blue-50/50 border-l-4 border-blue-500 p-4 rounded-r-xl">
            <p class="text-sm text-slate-700 italic leading-relaxed">
              ${p.parecerSocial ? `"${p.parecerSocial}"` : 'Nenhum parecer social cadastrado neste processo.'}
            </p>
          </div>
        </div>
      `;

      const actionRow = document.getElementById('drawer-admin-action-row');
      actionRow.innerHTML = '';

      const btnFechar = document.createElement('button');
      btnFechar.className = 'px-4 py-2 bg-white border border-slate-200 text-slate-700 text-sm font-bold rounded-xl hover:bg-slate-50 transition-colors shadow-sm';
      btnFechar.textContent = 'Fechar';
      btnFechar.onclick = fecharDrawerAdmin;
      actionRow.appendChild(btnFechar);

      if (p.statusAtual !== 'SUSPENSO') {
        const btnSusp = document.createElement('button');
        btnSusp.className = 'px-4 py-2 bg-white border border-red-200 text-red-600 text-sm font-bold rounded-xl hover:bg-red-50 transition-colors shadow-sm';
        btnSusp.textContent = 'Suspender Benefício';
        btnSusp.onclick = () => {
          if (confirm('Tem certeza de que deseja SUSPENDER administrativamente este benefício?')) {
            alterarStatusAdmin(p.id, 'SUSPENSO');
          }
        };
        actionRow.appendChild(btnSusp);
      } else {
        const btnReat = document.createElement('button');
        btnReat.className = 'px-4 py-2 bg-emerald-500 text-white text-sm font-bold rounded-xl hover:bg-emerald-600 transition-colors shadow-sm';
        btnReat.textContent = 'Reativar (Triagem)';
        btnReat.onclick = () => {
          if (confirm('Reativar este processo e retornar para a triagem geral?')) {
            alterarStatusAdmin(p.id, 'TRIAGEM');
          }
        };
        actionRow.appendChild(btnReat);
      }

      if (p.statusAtual !== 'ENCERRADO') {
        const btnEnce = document.createElement('button');
        btnEnce.className = 'px-4 py-2 bg-gov-700 text-white text-sm font-bold rounded-xl hover:bg-gov-800 transition-colors shadow-sm';
        btnEnce.textContent = 'Arquivar/Encerrar';
        btnEnce.onclick = () => {
          if (confirm('Deseja realmente arquivar e encerrar este processo?')) {
            alterarStatusAdmin(p.id, 'ENCERRADO');
          }
        };
        actionRow.appendChild(btnEnce);
      }

      const overlay = document.getElementById('drawer-overlay');
      const drawer = document.getElementById('ficha-drawer-admin');

      overlay.classList.remove('hidden');

      // allow paint
      requestAnimationFrame(() => {
        overlay.classList.remove('opacity-0');
        overlay.classList.add('opacity-100');
        drawer.classList.remove('translate-x-full');
        drawer.classList.add('translate-x-0');
      });
    }

    function fecharDrawerAdmin() {
      const overlay = document.getElementById('drawer-overlay');
      const drawer = document.getElementById('ficha-drawer-admin');

      overlay.classList.remove('opacity-100');
      overlay.classList.add('opacity-0');
      drawer.classList.remove('translate-x-0');
      drawer.classList.add('translate-x-full');

      setTimeout(() => {
        overlay.classList.add('hidden');
      }, 300);
    }

    // --- Função Global para exibir/ocultar dados sensíveis ---
    function toggleSigilo(btn) {
      try {
        if (window.event) window.event.stopPropagation();
        
        const wrapper = btn.closest('div') || btn.parentElement;
        if (!wrapper) return;
        
        const dataSpan = wrapper.querySelector('.confidential-data');
        if (!dataSpan) return;

        const hasBlurClass = dataSpan.classList.contains('blur-[4px]') || dataSpan.classList.contains('blur-[5px]');
        const hasBlurStyle = dataSpan.style.filter && dataSpan.style.filter.includes('blur');
        
        if (hasBlurClass || hasBlurStyle) {
          // Remove borrado
          dataSpan.classList.remove('blur-[4px]', 'blur-[5px]');
          dataSpan.style.filter = 'none';
          dataSpan.style.opacity = '1';
          btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg> Ocultar';
        } else {
          // Adiciona borrado
          dataSpan.classList.add('blur-[5px]');
          dataSpan.style.filter = 'blur(5px)';
          btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg> Exibir';
        }
      } catch (e) {
        alert("Erro no toggleSigilo: " + e.message);
      }
    }
    window.toggleSigilo = toggleSigilo;

    // --- ALERTA VISUAL ---
    function mostrarAlerta(tipo, msg) {
      const container = document.getElementById('admin-alert-container');
      const colorClasses = tipo === 'success'
        ? 'bg-emerald-50 border-emerald-200 text-emerald-700'
        : 'bg-red-50 border-red-200 text-red-700';

      container.innerHTML = `
        <div class="flex items-center gap-3 p-4 rounded-xl border ${colorClasses} shadow-sm">
          ${tipo === 'success'
            ? '<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>'
            : '<svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>'
          }
          <span class="font-medium text-sm"><strong>${tipo === 'success' ? 'Sucesso' : 'Atenção'}:</strong> ${msg}</span>
        </div>
      `;
      window.scrollTo({ top: 0, behavior: 'smooth' });
      setTimeout(() => { container.innerHTML = ''; }, 5000);
    }
  </script>

