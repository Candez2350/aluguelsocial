<!-- Modal Checklist Flutuante -->
<div id="checklist-modal" class="modal-overlay">
  <div class="modal-card" style="max-width: 600px;">
    <div class="modal-header">
      <h2 class="modal-title">Documentos Obrigatórios - SEI: <span id="modal-sei-num"></span></h2>
      <button class="modal-close" type="button" onclick="fecharChecklistModal()">&times;</button>
    </div>
    <div class="modal-body">
      <div id="modal-checklist-docs" class="checklist-container">
        <!-- preenchido por js -->
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" onclick="fecharChecklistModal()" class="btn-secondary">Fechar</button>
    </div>
  </div>
</div>

<!-- Oculto: Serialização dos Processos em JSON para leitura segura no Client-Side -->
<textarea id="processos-json-data" style="display: none;"><%- JSON.stringify(processos) %></textarea>

<script>
  // Helper for masking CPF
  function mascaraCPF(i) {
    let v = i.value;
    if (isNaN(v.charAt(v.length-1))) {
      i.value = v.substring(0, v.length-1);
      return;
    }
    i.setAttribute("maxlength", "14");
    if (v.length == 3 || v.length == 7) i.value += ".";
    if (v.length == 11) i.value += "-";
  }

  // Estado da paginação
  const paginasAtuais = {
    'table-processos': 1
  };
  const limitesAtuais = {
    'table-processos': 5
  };

  // Aplica paginação em uma tabela específica
  function aplicarPaginacao(tableId) {
    const rows = Array.from(document.querySelectorAll(`#${tableId} tbody .processo-row`));
    const rowsFiltradas = rows.filter(row => row.getAttribute('data-filtered-out') !== 'true');
    const totalItens = rowsFiltradas.length;
    const limit = limitesAtuais[tableId] || 5;
    const totalPaginas = Math.max(1, Math.ceil(totalItens / limit));
    
    if (paginasAtuais[tableId] > totalPaginas) {
      paginasAtuais[tableId] = totalPaginas;
    }
    if (paginasAtuais[tableId] < 1) {
      paginasAtuais[tableId] = 1;
    }
    
    const paginaAtual = paginasAtuais[tableId];
    const startIndex = (paginaAtual - 1) * limit;
    const endIndex = Math.min(startIndex + limit, totalItens);
    
    rows.forEach(row => {
      row.style.display = 'none';
    });
    
    rowsFiltradas.slice(startIndex, endIndex).forEach(row => {
      row.style.display = '';
    });
    
    const infoEl = document.getElementById(`info-${tableId}`);
    if (infoEl) {
      if (totalItens === 0) {
        infoEl.textContent = 'Nenhum registro encontrado';
      } else {
        infoEl.textContent = `Exibindo ${startIndex + 1} a ${endIndex} de ${totalItens} registros`;
      }
    }
    
    const btnPrev = document.getElementById(`btn-prev-${tableId}`);
    const btnNext = document.getElementById(`btn-next-${tableId}`);
    
    if (btnPrev) btnPrev.disabled = paginaAtual === 1;
    if (btnNext) btnNext.disabled = paginaAtual === totalPaginas;
  }
  
  function prevPage(tableId) {
    if (paginasAtuais[tableId] > 1) {
      paginasAtuais[tableId]--;
      aplicarPaginacao(tableId);
    }
  }
  
  function nextPage(tableId) {
    const rows = Array.from(document.querySelectorAll(`#${tableId} tbody .processo-row`));
    const rowsFiltradas = rows.filter(row => row.getAttribute('data-filtered-out') !== 'true');
    const totalItens = rowsFiltradas.length;
    const limit = limitesAtuais[tableId] || 5;
    const totalPaginas = Math.ceil(totalItens / limit);
    
    if (paginasAtuais[tableId] < totalPaginas) {
      paginasAtuais[tableId]++;
      aplicarPaginacao(tableId);
    }
  }
  
  function changeLimit(tableId) {
    const select = document.getElementById(`limit-${tableId}`);
    if (select) {
      limitesAtuais[tableId] = parseInt(select.value, 10);
      paginasAtuais[tableId] = 1;
      aplicarPaginacao(tableId);
    }
  }

  // Instant Smart Filter
  function filterTable() {
    const query = document.getElementById('search-input').value.toLowerCase().trim();
    const rows = document.querySelectorAll('#table-processos tbody .processo-row');
    
    let visibleCount = 0;
    
    rows.forEach(row => {
      const sei = row.getAttribute('data-sei').toLowerCase();
      const nome = row.getAttribute('data-nome').toLowerCase();
      const cpf = row.getAttribute('data-cpf').replace(/\D/g, ''); 
      const queryClean = query.replace(/\D/g, '');
      
      let textMatches = false;
      if (query === '') {
        textMatches = true;
      } else {
        const queryMatchesSei = sei.includes(query);
        const queryMatchesNome = nome.includes(query);
        const queryMatchesCpf = cpf.includes(queryClean) || row.getAttribute('data-cpf').includes(query);
        textMatches = queryMatchesSei || queryMatchesNome || queryMatchesCpf;
      }
      
      if (textMatches) {
        row.setAttribute('data-filtered-out', 'false');
        visibleCount++;
      } else {
        row.setAttribute('data-filtered-out', 'true');
      }
    });

    const tableBody = document.querySelector('#table-processos tbody');
    let noMatchRow = document.getElementById('no-match-row');
    
    if (visibleCount === 0) {
      if (!noMatchRow) {
        noMatchRow = document.createElement('tr');
        noMatchRow.id = 'no-match-row';
        noMatchRow.innerHTML = `
          <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 3rem;">
            Nenhum processo correspondente aos filtros foi encontrado.
          </td>
        `;
        tableBody.appendChild(noMatchRow);
      } else {
        noMatchRow.style.display = '';
      }
      const originalNoProcess = tableBody.querySelector('.no-process-row');
      if (originalNoProcess) {
        originalNoProcess.style.display = 'none';
      }
    } else {
      if (noMatchRow) {
        noMatchRow.style.display = 'none';
      }
    }
    
    paginasAtuais['table-processos'] = 1;
    aplicarPaginacao('table-processos');
  }

  function abrirCadastroModal() {
    document.getElementById('cadastro-modal').classList.add('open');
  }

  function fecharCadastroModal() {
    document.getElementById('cadastro-modal').classList.remove('open');
    document.getElementById('form-cadastro').reset();
  }

  function abrirEdicaoModal(processoId) {
    const processos = JSON.parse(document.getElementById('processos-json-data').value);
    const p = processos.find(proc => proc.id === processoId);
    
    if (!p) {
      alert('Processo não encontrado.');
      return;
    }
    
    document.getElementById('edit-id').value = p.id;
    document.getElementById('edit-nome').value = p.beneficiaria.nome;
    document.getElementById('edit-cpf').value = p.beneficiaria.cpf;
    document.getElementById('edit-nis').value = p.beneficiaria.nisCadunico;
    
    if (p.beneficiaria.dataNascimento) {
      document.getElementById('edit-nascimento').value = p.beneficiaria.dataNascimento.substring(0, 10);
    }
    
    document.getElementById('edit-telefone').value = p.beneficiaria.telefone;
    document.getElementById('edit-renda').value = p.beneficiaria.rendaPerCapitaDigitada;
    document.getElementById('edit-bairro').value = p.beneficiaria.bairro;
    document.getElementById('edit-cidade').value = p.beneficiaria.cidade;
    
    try {
      const bank = JSON.parse(p.beneficiaria.dadosBancariosManuais);
      document.getElementById('edit-banco').value = bank.banco || '';
      document.getElementById('edit-agencia').value = bank.agencia || '';
      document.getElementById('edit-conta').value = bank.conta || '';
    } catch(e) {
      document.getElementById('edit-banco').value = '';
      document.getElementById('edit-agencia').value = '';
      document.getElementById('edit-conta').value = '';
    }
    
    document.getElementById('edit-sei-processo').value = p.numeroProcessoSei;
    document.getElementById('edit-tem-mpu').checked = (p.tipoEsteira === 'SIMPLIFICADO');
    
    document.getElementById('edicao-modal').classList.add('open');
  }

  function fecharEdicaoModal() {
    document.getElementById('edicao-modal').classList.remove('open');
    document.getElementById('form-edicao').reset();
  }

  async function cadastrarInscricao(e) {
    e.preventDefault();
    
    const body = {
      nome: document.getElementById('ben-nome').value,
      cpf: document.getElementById('ben-cpf').value,
      nisCadunico: document.getElementById('ben-nis').value,
      dataNascimento: document.getElementById('ben-nascimento').value,
      telefone: document.getElementById('ben-telefone').value,
      rendaPerCapitaDigitada: document.getElementById('ben-renda').value,
      bairro: document.getElementById('ben-bairro').value,
      cidade: document.getElementById('ben-cidade').value,
      banco: document.getElementById('ben-banco').value,
      agencia: document.getElementById('ben-agencia').value,
      conta: document.getElementById('ben-conta').value,
      numeroProcessoSei: document.getElementById('sei-processo').value,
      temMPU: document.getElementById('tem-mpu').checked
    };

    try {
      const response = await fetch('/api/processos', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(body)
      });
      
      const res = await response.json();
      
      if (res.success) {
        window.location.reload();
      } else {
        mostrarAlerta('danger', res.error);
        fecharCadastroModal();
      }
    } catch (error) {
      mostrarAlerta('danger', 'Erro ao cadastrar inscrição.');
      fecharCadastroModal();
    }
  }

  async function editarInscricao(e) {
    e.preventDefault();
    
    const id = document.getElementById('edit-id').value;
    const body = {
      nome: document.getElementById('edit-nome').value,
      cpf: document.getElementById('edit-cpf').value,
      nisCadunico: document.getElementById('edit-nis').value,
      dataNascimento: document.getElementById('edit-nascimento').value,
      telefone: document.getElementById('edit-telefone').value,
      rendaPerCapitaDigitada: document.getElementById('edit-renda').value,
      bairro: document.getElementById('edit-bairro').value,
      cidade: document.getElementById('edit-cidade').value,
      banco: document.getElementById('edit-banco').value,
      agencia: document.getElementById('edit-agencia').value,
      conta: document.getElementById('edit-conta').value,
      numeroProcessoSei: document.getElementById('edit-sei-processo').value,
      temMPU: document.getElementById('edit-tem-mpu').checked
    };

    try {
      const response = await fetch(`/api/processos/${id}/editar`, {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(body)
      });
      
      const res = await response.json();
      
      if (res.success) {
        fecharEdicaoModal();
        window.location.reload();
      } else {
        mostrarAlerta('danger', res.error);
        fecharEdicaoModal();
      }
    } catch (error) {
      mostrarAlerta('danger', 'Erro ao salvar alterações da inscrição.');
      fecharEdicaoModal();
    }
  }

  async function avancarStatus(id, status) {
    try {
      const response = await fetch(`/api/processos/${id}/status`, {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ status })
      });
      
      const res = await response.json();
      
      if (res.success) {
        window.location.reload();
      } else {
        mostrarAlerta('danger', res.error);
      }
    } catch (error) {
      mostrarAlerta('danger', 'Erro ao avançar status.');
    }
  }

  function abrirChecklistModal(processoId) {
    const processos = JSON.parse(document.getElementById('processos-json-data').value);
    const p = processos.find(proc => proc.id === processoId);
    
    if (!p) {
      alert('Processo não encontrado.');
      return;
    }
    
    document.getElementById('modal-sei-num').textContent = p.numeroProcessoSei;
    
    const container = document.getElementById('modal-checklist-docs');
    container.innerHTML = '';
    
    p.documentos.forEach(doc => {
      const div = document.createElement('div');
      div.className = 'checklist-item';
      
      const verificado = doc.verificadoManualmente;
      const statusBadge = verificado 
        ? '<span class="checklist-status-badge completo">Verificado / Salvo</span>'
        : '<span class="checklist-status-badge pendente">Pendente</span>';
      
      const isEditable = (p.statusAtual !== 'ENCERRADO' && p.statusAtual !== 'SUSPENSO');
      
      const toggleAction = verificado
        ? `<button class="btn-danger-outline" style="font-size:0.75rem; padding:0.4rem 0.8rem;" onclick="processarDoc('${doc.id}', false)">Remover</button>`
        : `<button class="btn-primary" style="font-size:0.75rem; padding:0.4rem 0.8rem; width:auto;" onclick="processarDoc('${doc.id}', true)">Simular Upload & Confirmar</button>`;

      div.innerHTML = `
        <div class="checklist-info">
          <span class="checklist-title">${doc.tipoDocumento}</span>
          <span class="checklist-desc">${doc.tipoDocumento === 'MPU' ? 'Medida Protetiva de Urgência Judicial' : 'Documento pessoal obrigatório'}</span>
        </div>
        <div class="checklist-actions">
          ${statusBadge}
          ${isEditable ? toggleAction : ''}
        </div>
      `;
      container.appendChild(div);
    });
    
    document.getElementById('checklist-modal').classList.add('open');
  }

  function fecharChecklistModal() {
    document.getElementById('checklist-modal').classList.remove('open');
  }

  async function processarDoc(docId, verificadoVal) {
    try {
      const response = await fetch(`/api/documentos/${docId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ verificado: verificadoVal })
      });
      
      const res = await response.json();
      if (res.success) {
        fecharChecklistModal();
        window.location.reload();
      }
    } catch (error) {
      alert('Erro ao atualizar checklist.');
    }
  }

  function mostrarAlerta(tipo, msg) {
    const container = document.getElementById('operador-alert-container');
    container.innerHTML = `
      <div class="alert alert-${tipo}">
        <strong>${tipo === 'success' ? 'Sucesso' : 'Erro'}:</strong> ${msg}
      </div>
    `;
    window.scrollTo({ top: 0, behavior: 'smooth' });
    setTimeout(() => { container.innerHTML = ''; }, 5000);
  }

  // Explicit window bindings
  window.abrirCadastroModal = abrirCadastroModal;
  window.fecharCadastroModal = fecharCadastroModal;
  window.abrirEdicaoModal = abrirEdicaoModal;
  window.fecharEdicaoModal = fecharEdicaoModal;
  window.abrirChecklistModal = abrirChecklistModal;
  window.fecharChecklistModal = fecharChecklistModal;
  window.processarDoc = processarDoc;
  window.avancarStatus = avancarStatus;
  window.mascaraCPF = mascaraCPF;
  window.prevPage = prevPage;
  window.nextPage = nextPage;
  window.changeLimit = changeLimit;
  window.filterTable = filterTable;

  document.addEventListener('DOMContentLoaded', () => {
    const rows = document.querySelectorAll('#table-processos tbody .processo-row');
    rows.forEach(row => {
      row.setAttribute('data-filtered-out', 'false');
    });
    aplicarPaginacao('table-processos');

    rows.forEach(row => {
      row.style.cursor = 'pointer';
      row.addEventListener('click', (e) => {
        if (e.target.closest('.action-btn-group') || e.target.closest('.btn-toggle-sigilo')) return;
        const id = row.getAttribute('data-id');
        abrirChecklistModal(id);
      });
    });
  });
</script>

<%- include('../partials/footer') %>
