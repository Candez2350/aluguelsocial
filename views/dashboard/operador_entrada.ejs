<%- include('../partials/header') %>

<div id="operador-alert-container"></div>

<!-- Cabeçalho da Fila de Trabalho do Operador -->
<div class="mb-8 p-6 bg-white border border-slate-200 rounded-xl shadow-sm flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
  <div>
    <h1 class="text-xl font-display font-bold text-slate-800">Fila de Entrada e Triagem</h1>
    <p class="text-sm text-slate-500 mt-1 font-medium">Cadastre novos requerimentos e gerencie documentos obrigatórios das esteiras comuns e simplificadas.</p>
  </div>
  <button onclick="abrirCadastroModal()" class="btn-primary py-2.5 px-5 text-sm font-semibold uppercase tracking-wider flex items-center gap-2 shadow-sm rounded-lg" style="width: auto;">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
    Novo Requerimento
  </button>
</div>

<!-- Barra de Ações e Filtro Rápido -->
<div class="controls-row mb-6">
  <div style="flex-grow: 1;"></div>
  <div class="search-container min-w-[300px]">
    <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input type="text" id="search-input" class="search-input" placeholder="Filtrar por Processo SEI, Cidadã ou CPF..." onkeyup="filterTable()">
  </div>
</div>

<!-- Tabela de Processos (Full-Width) -->
<div class="bg-white border border-slate-200 shadow-sm rounded-xl overflow-hidden flex flex-col mb-8">
  <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50">
    <h2 class="text-gov-900 font-display font-bold text-lg">Processos Inseridos recentemente</h2>
  </div>
  
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse" id="table-processos">
      <thead>
        <tr class="bg-slate-50 text-slate-500 font-semibold text-xs tracking-wider uppercase border-b border-slate-200">
          <th class="px-6 py-4">Processo SEI</th>
          <th class="px-6 py-4">Cidadã (CPF)</th>
          <th class="px-6 py-4">Esteira</th>
          <th class="px-6 py-4">Status</th>
          <th class="px-6 py-4 text-right">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% if (processos.length === 0) { %>
          <tr class="no-process-row">
            <td colspan="5" class="text-center text-slate-500 py-12 text-sm">Nenhum processo cadastrado no momento.</td>
          </tr>
        <% } else { %>
          <% processos.forEach(p => { %>
            <tr class="processo-row group hover:bg-slate-50 cursor-pointer transition-colors text-sm" 
                data-id="<%= p.id %>"
                data-sei="<%= p.numeroProcessoSei %>" 
                data-nome="<%= p.beneficiaria.nome %>" 
                data-cpf="<%= p.beneficiaria.cpf %>"
                data-status="<%= p.statusAtual %>">
              <td class="px-6 py-4 font-semibold text-slate-900"><%= p.numeroProcessoSei %></td>
              <td class="px-6 py-4">
                <div class="confidential-wrapper flex items-center gap-1.5" onclick="event.stopPropagation();">
                  <span class="confidential-data blurred select-none text-slate-700"><%= p.beneficiaria.nome %> (<%= p.beneficiaria.cpf %>)</span>
                  <button class="text-gov-500 hover:text-gov-700 text-[10px] font-bold px-2 py-0.5 rounded border border-slate-200 bg-white btn-toggle-sigilo" onclick="toggleSigilo(this)">Exibir</button>
                </div>
              </td>
              <td class="px-6 py-4">
                <span class="esteira-tag <%= p.tipoEsteira.toLowerCase() %>">
                  <%= p.tipoEsteira %>
                </span>
              </td>
              <td class="px-6 py-4">
                <span class="status-tag <%= p.statusAtual.toLowerCase() %> text-[10px] px-2 py-1 rounded font-bold uppercase tracking-wide border border-slate-100">
                  <%= p.statusAtual.replace('_', ' ') %>
                </span>
              </td>
              <td class="px-6 py-4 text-right" onclick="event.stopPropagation();">
                <div class="action-btn-group flex gap-2 justify-end">
                  <button class="px-2.5 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50" onclick="abrirChecklistModal('<%= p.id %>')" title="Gerenciar Documentos">Checklist</button>
                  
                  <% 
                    const statusPermitidosEdicao = ['RASCUNHO', 'RECURSO', 'SUSPENSO', 'TRIAGEM'];
                    if (statusPermitidosEdicao.includes(p.statusAtual)) { 
                  %>
                    <button class="px-2.5 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50" onclick="abrirEdicaoModal('<%= p.id %>')" title="Editar dados">Editar</button>
                  <% } %>

                  <% if (p.statusAtual === 'RASCUNHO') { %>
                    <button class="px-2.5 py-1.5 text-xs font-medium rounded-lg bg-gov-700 text-white hover:bg-gov-800 transition-colors" onclick="avancarStatus('<%= p.id %>', 'TRIAGEM')" title="Enviar para Triagem">Triar</button>
                  <% } else if (p.statusAtual === 'TRIAGEM') { %>
                    <button class="px-2.5 py-1.5 text-xs font-medium rounded-lg bg-gov-700 text-white hover:bg-gov-800 transition-colors" onclick="avancarStatus('<%= p.id %>', 'ANALISE')" title="Enviar para Análise">Análise</button>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Paginação para Processos Cadastrados -->
  <div class="px-6 py-4 border-t border-slate-100 bg-slate-50/50 flex items-center justify-between gap-4 text-xs">
    <div class="flex items-center gap-2 text-slate-600 font-medium">
      <select id="limit-table-processos" class="bg-white border border-slate-200 rounded px-1.5 py-0.5 text-slate-700 outline-none focus:border-gov-500" onchange="changeLimit('table-processos')">
        <option value="5" selected>5</option>
        <option value="10">10</option>
        <option value="15">15</option>
      </select>
    </div>
    <div id="info-table-processos" class="text-slate-500 font-medium">
      Exibindo 1 a 5 de 15 registros
    </div>
    <div class="flex items-center gap-1">
      <button id="btn-prev-table-processos" class="px-2 py-1 border border-slate-200 bg-white text-slate-700 rounded hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed" onclick="prevPage('table-processos')">Ant.</button>
      <button id="btn-next-table-processos" class="px-2 py-1 border border-slate-200 bg-white text-slate-700 rounded hover:bg-slate-50 disabled:opacity-50 disabled:cursor-not-allowed" onclick="nextPage('table-processos')">Próx.</button>
    </div>
  </div>
</div>

<!-- Modal Novo Requerimento (Cadastro) -->
<div id="cadastro-modal" class="modal-overlay">
  <div class="modal-card" style="max-width: 800px;">
    <div class="modal-header">
      <h2 class="modal-title">Cadastrar Novo Requerimento</h2>
      <button class="modal-close" type="button" onclick="fecharCadastroModal()">&times;</button>
    </div>
    <form id="form-cadastro" onsubmit="cadastrarInscricao(event)">
      <div class="modal-body">
        
        <h3 class="text-xs font-bold text-gov-700 uppercase tracking-wider mb-4 pb-2 border-b border-slate-100">Dados Pessoais</h3>
        
        <div class="form-group mb-4">
          <label for="ben-nome" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">Nome Completo</label>
          <input type="text" id="ben-nome" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required placeholder="Ex: Antônia Maria de Jesus">
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          <div class="form-group">
            <label for="ben-cpf" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">CPF</label>
            <input type="text" id="ben-cpf" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required placeholder="000.000.000-00" oninput="mascaraCPF(this)">
          </div>
          <div class="form-group">
            <label for="ben-nis" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">NIS CadÚnico</label>
            <input type="text" id="ben-nis" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required placeholder="Ex: 12345678901">
          </div>
          <div class="form-group">
            <label for="ben-nascimento" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">Data de Nascimento</label>
            <input type="date" id="ben-nascimento" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required>
          </div>
          <div class="form-group">
            <label for="ben-telefone" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">Telefone de Contato</label>
            <input type="text" id="ben-telefone" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required placeholder="(00) 00000-0000">
          </div>
        </div>

        <h3 class="text-xs font-bold text-gov-700 uppercase tracking-wider mb-4 pb-2 border-b border-slate-100">Renda e Residência</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
          <div class="form-group">
            <label for="ben-renda" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">Renda Per Capita (R$)</label>
            <input type="number" step="0.01" min="0" id="ben-renda" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required placeholder="Ex: 180.00">
          </div>
          <div class="form-group">
            <label for="ben-bairro" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">Bairro</label>
            <input type="text" id="ben-bairro" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required placeholder="Ex: Madureira">
          </div>
          <div class="form-group">
            <label for="ben-cidade" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">Cidade</label>
            <input type="text" id="ben-cidade" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required placeholder="Ex: Rio de Janeiro" value="Rio de Janeiro">
          </div>
        </div>

        <h3 class="text-xs font-bold text-gov-700 uppercase tracking-wider mb-4 pb-2 border-b border-slate-100">Conta para Depósito</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
          <div class="form-group">
            <label for="ben-banco" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">Banco (Código)</label>
            <input type="text" id="ben-banco" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required placeholder="Ex: 001">
          </div>
          <div class="form-group">
            <label for="ben-agencia" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">Agência</label>
            <input type="text" id="ben-agencia" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required placeholder="Ex: 1234">
          </div>
          <div class="form-group">
            <label for="ben-conta" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">Conta / DV</label>
            <input type="text" id="ben-conta" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required placeholder="Ex: 56789-0">
          </div>
        </div>

        <h3 class="text-xs font-bold text-gov-700 uppercase tracking-wider mb-4 pb-2 border-b border-slate-100">Dados Administrativos</h3>
        
        <div class="form-group mb-4">
          <label for="sei-processo" class="block text-slate-600 font-semibold text-xs mb-2 tracking-wide uppercase">Número do Processo SEI</label>
          <input type="text" id="sei-processo" class="w-full bg-white border border-slate-200 text-slate-900 px-4 py-2.5 rounded-xl text-sm placeholder-slate-400 focus:outline-none focus:border-gov-500 focus:ring-4 focus:ring-gov-500/10 transition-all shadow-sm" required placeholder="Ex: SEI-12345/2026">
        </div>

        <div class="flex items-center gap-3 p-4 rounded-xl border border-slate-200 bg-slate-50/50">
          <input type="checkbox" id="tem-mpu" name="temMPU" class="w-4 h-4 text-gov-600 border-slate-300 rounded focus:ring-gov-500 cursor-pointer">
          <label for="tem-mpu" class="text-xs text-slate-700 font-semibold cursor-pointer">
            Cidadã possui Medida Protetiva de Urgência (MPU)?
            <span class="block font-normal text-[11px] text-slate-500 mt-1">Marcar esta opção ativa automaticamente a esteira Judicial Simplificada (SLA de 72h).</span>
          </label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" onclick="fecharCadastroModal()" class="btn-secondary">Cancelar</button>
        <button type="submit" class="btn-primary" style="width: auto;">Cadastrar Requerimento</button>
      </div>
    </form>
  </div>
</div>

