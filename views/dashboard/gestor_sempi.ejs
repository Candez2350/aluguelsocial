        <select id="filtro-sla-auditoria" class="pagination-select" style="padding: 0.35rem 2rem 0.35rem 0.75rem;" onchange="filtrarAuditoria()">
          <option value="TODOS" selected>Todos os Prazos</option>
          <option value="ATRASADOS">Apenas Atrasados</option>
          <option value="EM_DIA">Em Dia</option>
        </select>
