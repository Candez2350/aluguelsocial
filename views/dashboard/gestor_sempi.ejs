      <!-- Pareceres -->
      <div class="drawer-section">
        <div class="drawer-section-title">Histórico de Pareceres</div>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="background-color: var(--bg-app); border-left: 4px solid var(--primary); padding: 1rem; border-radius: 4px;">
            <strong style="display: block; font-size: 0.8rem; text-transform: uppercase; color: var(--primary); margin-bottom: 4px;">Parecer Social (SUAS)</strong>
            <p style="font-size: 0.9rem; font-style: italic; line-height: 1.4; margin: 0;">
              ${p.parecerSocial ? `"${p.parecerSocial}"` : 'Sem parecer social emitido.'}
            </p>
          </div>
          <div style="background-color: var(--bg-app); border-left: 4px solid var(--secondary); padding: 1rem; border-radius: 4px;">
            <strong style="display: block; font-size: 0.8rem; text-transform: uppercase; color: var(--secondary); margin-bottom: 4px;">Parecer / Relatório Técnico</strong>
            <p style="font-size: 0.9rem; font-style: italic; line-height: 1.4; margin: 0;">
              ${p.parecerTecnico ? `"${p.parecerTecnico}"` : 'Sem parecer técnico adicional.'}
            </p>
          </div>
        </div>
      </div>
    `;

    const footer = document.getElementById('drawer-actions-footer');
    if (p.statusAtual === 'APROVADO') {
      footer.innerHTML = `
        <button onclick="fecharDrawerFicha()" class="px-4 py-2 bg-white border border-slate-200 text-slate-700 text-sm font-bold rounded-xl hover:bg-slate-50 transition-colors shadow-sm">Fechar</button>
        <button class="btn-action-primary" onclick="homologarParaPagamento('${p.id}')">Homologar Pagamento</button>
      `;
    } else {
      footer.innerHTML = `
        <button onclick="fecharDrawerFicha()" class="px-4 py-2 bg-white border border-slate-200 text-slate-700 text-sm font-bold rounded-xl hover:bg-slate-50 transition-colors shadow-sm">Fechar</button>
      `;
    }

    const overlay = document.getElementById('drawer-overlay');
    const drawer = document.getElementById('ficha-drawer');
    overlay.style.display = 'block';
    setTimeout(() => {
      overlay.classList.add('open');
      drawer.classList.add('open');
    }, 10);
  }

  function fecharDrawerFicha() {
    const overlay = document.getElementById('drawer-overlay');
    const drawer = document.getElementById('ficha-drawer');
    
    overlay.classList.remove('open');
    drawer.classList.remove('open');
    
    setTimeout(() => {
      overlay.style.display = 'none';
    }, 300);
  }

  function mostrarAlerta(tipo, msg) {
    const container = document.getElementById('gestor-alert-container');
    if (!container) return;
    container.innerHTML = `
      <div class="alert alert-${tipo}">
        <strong>${tipo === 'success' ? 'Sucesso' : 'Erro'}:</strong> ${msg}
      </div>
    `;
    window.scrollTo({ top: 0, behavior: 'smooth' });
    setTimeout(() => { container.innerHTML = ''; }, 5000);
  }

  function calcularIdadeNum(nascStr) {
    if (!nascStr) return 0;
    const nasc = new Date(nascStr);
    const hoje = new Date();
    let idade = hoje.getFullYear() - nasc.getFullYear();
    const m = hoje.getMonth() - nasc.getMonth();
    if (m < 0 || (m === 0 && hoje.getDate() < nasc.getDate())) {
      idade--;
    }
    return idade;
  }

  // --- CARREGAMENTO DE GRÁFICOS DINÂMICOS (CSS BARS UNIFICADO & YOY TABLE) ---
  async function carregarGraficosEstatisticos() {
    try {
      const response = await fetch('/api/relatorios/estatisticas');
      const data = await response.json();

      // A. Cálculos de Vulnerabilidade MDS (Renda per Capita)
      const extPobreza = dbProcessos.filter(p => p.beneficiaria.rendaPerCapitaDigitada <= 105).length;
      const pobreza = dbProcessos.filter(p => p.beneficiaria.rendaPerCapitaDigitada > 105 && p.beneficiaria.rendaPerCapitaDigitada <= 218).length;
      const baixaRenda = dbProcessos.filter(p => p.beneficiaria.rendaPerCapitaDigitada > 218).length;
      const totalVulneraveis = Math.max(1, extPobreza + pobreza + baixaRenda);

      const percExt = ((extPobreza / totalVulneraveis) * 100).toFixed(1);
      const percPob = ((pobreza / totalVulneraveis) * 100).toFixed(1);
      const percBax = ((baixaRenda / totalVulneraveis) * 100).toFixed(1);

      const cVuln = document.getElementById('analytics-vulnerabilidade');
      cVuln.innerHTML = `
        <div style="display:flex; flex-direction:column; justify-content:space-between; min-height:120px; padding: 0.25rem 0;">
          <div>
            <div style="display:flex; justify-content:space-between; font-size:0.85rem; font-weight:600; margin-bottom:4px;">
              <span style="color:#b91c1c;">Extrema Pobreza (até R$ 105)</span>
              <span>${extPobreza} (${percExt}%)</span>
            </div>
            <div style="width:100%; height:10px; background:#f1f5f9; border-radius:5px; overflow:hidden;">
              <div style="width:${percExt}%; height:100%; background:#b91c1c;"></div>
            </div>
          </div>
          <div>
            <div style="display:flex; justify-content:space-between; font-size:0.85rem; font-weight:600; margin-bottom:4px;">
              <span style="color:#d97706;">Pobreza (R$ 105 a R$ 218)</span>
              <span>${pobreza} (${percPob}%)</span>
            </div>
            <div style="width:100%; height:10px; background:#f1f5f9; border-radius:5px; overflow:hidden;">
              <div style="width:${percPob}%; height:100%; background:#d97706;"></div>
            </div>
          </div>
          <div>
            <div style="display:flex; justify-content:space-between; font-size:0.85rem; font-weight:600; margin-bottom:4px;">
              <span style="color:#2563eb;">Baixa Renda (acima de R$ 218)</span>
              <span>${baixaRenda} (${percBax}%)</span>
            </div>
            <div style="width:100%; height:10px; background:#f1f5f9; border-radius:5px; overflow:hidden;">
              <div style="width:${percBax}%; height:100%; background:#2563eb;"></div>
            </div>
          </div>
        </div>
      `;

      // B. Cálculos de Prioridades de Proteção Especial (SUAS)
      const idosas = dbProcessos.filter(p => calcularIdadeNum(p.beneficiaria.dataNascimento) >= 60).length;
      const cadUnico = dbProcessos.filter(p => p.beneficiaria.nisCadunico && p.beneficiaria.nisCadunico !== 'N/A' && p.beneficiaria.nisCadunico !== '').length;
      const jovens = dbProcessos.filter(p => calcularIdadeNum(p.beneficiaria.dataNascimento) < 30).length;
      const totalGeral = Math.max(1, dbProcessos.length);

      const cPrioridades = document.getElementById('analytics-prioridades');
      cPrioridades.innerHTML = `
        <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; text-align:center;">
          <div style="background:#fff7ed; border:1px solid #ffedd5; padding:1.25rem 1rem; border-radius:var(--radius-md); display: flex; flex-direction: column; justify-content: space-between; min-height: 120px;">
            <span style="display:block; font-size:0.7rem; font-weight:700; color:#c2410c; text-transform:uppercase; margin-bottom:4px;">Grupo Idoso (60+)</span>
            <strong style="font-size:1.5rem; color:#ea580c; display:block; margin: auto 0;">${idosas}</strong>
            <span style="display:block; font-size:0.65rem; color:var(--text-muted); margin-top:2px;">${((idosas/totalGeral)*100).toFixed(1)}% do total</span>
          </div>
          <div style="background:#eff6ff; border:1px solid #dbeafe; padding:1.25rem 1rem; border-radius:var(--radius-md); display: flex; flex-direction: column; justify-content: space-between; min-height: 120px;">
            <span style="display:block; font-size:0.7rem; font-weight:700; color:#1d4ed8; text-transform:uppercase; margin-bottom:4px;">NIS CadÚnico</span>
            <strong style="font-size:1.5rem; color:#2563eb; display:block; margin: auto 0;">${cadUnico}</strong>
            <span style="display:block; font-size:0.65rem; color:var(--text-muted); margin-top:2px;">${((cadUnico/totalGeral)*100).toFixed(1)}% integrado</span>
          </div>
          <div style="background:#ecfdf5; border:1px solid #d1fae5; padding:1.25rem 1rem; border-radius:var(--radius-md); display: flex; flex-direction: column; justify-content: space-between; min-height: 120px;">
            <span style="display:block; font-size:0.7rem; font-weight:700; color:#047857; text-transform:uppercase; margin-bottom:4px;">Jovens Adultas</span>
            <strong style="font-size:1.5rem; color:#10b981; display:block; margin: auto 0;">${jovens}</strong>
            <span style="display:block; font-size:0.65rem; color:var(--text-muted); margin-top:2px;">Sub-30: ${((jovens/totalGeral)*100).toFixed(1)}%</span>
          </div>
        </div>
      `;

      // C. Explosão de Status dos Ingressos (Filtrável por Mês/Ano)
      if (!window.selectedExplosaoPeriodo) {
        window.selectedExplosaoPeriodo = '4-2026'; // Maio/2026 default
      }
      
      const [mesStr, anoStr] = window.selectedExplosaoPeriodo.split('-');
      const anoAtual = parseInt(anoStr, 10);
      const mesAtualNum = parseInt(mesStr, 10);
      const nomeMeses = ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'];
      
      const tituloExplosao = document.getElementById('titulo-explosao-mes');
      if (tituloExplosao) {
        tituloExplosao.textContent = `Explosão de Status dos Ingressos (${nomeMeses[mesAtualNum]}/${anoAtual})`;
      }

      const selectExplosaoEl = document.getElementById('filtro-mes-ano-explosao');
      if (selectExplosaoEl) {
        selectExplosaoEl.value = window.selectedExplosaoPeriodo;
      }

      const ingressosDoMes = dbProcessos.filter(p => {
        const d = new Date(p.dataCriacao);
        return d.getFullYear() === anoAtual && d.getMonth() === mesAtualNum;
      });

      const statusesDoMes = {
        'TRIAGEM': 0,
        'ANALISE': 0,
        'APROVADO': 0,
        'APTO_PAGAMENTO': 0,
        'INDEFERIDO': 0
      };

      ingressosDoMes.forEach(p => {
        if (statusesDoMes[p.statusAtual] !== undefined) {
          statusesDoMes[p.statusAtual]++;
        }
      });

      const cExplosao = document.getElementById('analytics-explosao-mes');
      if (cExplosao) {
        cExplosao.innerHTML = '';
        if (ingressosDoMes.length === 0) {
          cExplosao.innerHTML = `<p style="color: var(--text-muted); text-align: center; grid-column: 1 / -1; padding: 1.5rem;">Nenhum requerimento ingressado em ${nomeMeses[mesAtualNum]}/${anoAtual} até o momento.</p>`;
        } else {
          const statusLabels = {
            'TRIAGEM': { label: 'Em Triagem', bg: 'rgba(30, 58, 138, 0.08)', text: 'var(--primary)' },
            'ANALISE': { label: 'Em Análise', bg: 'rgba(217, 119, 6, 0.08)', text: 'var(--secondary)' },
            'APROVADO': { label: 'Aprovados', bg: 'rgba(16, 185, 129, 0.08)', text: 'var(--success)' },
            'APTO_PAGAMENTO': { label: 'Apto Pagamento', bg: 'rgba(37, 99, 235, 0.08)', text: '#2563eb' },
            'INDEFERIDO': { label: 'Indeferidos', bg: 'rgba(239, 68, 68, 0.08)', text: '#ef4444' }
          };

          Object.keys(statusesDoMes).forEach(st => {
            const qtd = statusesDoMes[st];
            const info = statusLabels[st];
            const percent = ((qtd / Math.max(1, ingressosDoMes.length)) * 100).toFixed(0);
            cExplosao.innerHTML += `
              <div style="background: ${info.bg}; border: 1.5px solid rgba(0,0,0,0.03); padding: 1.25rem 1rem; border-radius: var(--radius-md); text-align: center; display: flex; flex-direction: column; justify-content: space-between; min-height: 120px;">
                <span style="display: block; font-size: 0.75rem; font-weight: 700; color: ${info.text}; text-transform: uppercase; margin-bottom: 6px;">${info.label}</span>
                <strong style="font-size: 1.85rem; color: ${info.text}; font-family: var(--font-title); display: block; margin: auto 0 2px 0;">${qtd}</strong>
                <span style="font-size: 0.7rem; color: var(--text-muted); font-weight: 600;">${percent}% dos ingressos</span>
              </div>
            `;
          });
        }
      }

      // D. População da Tabela Histórica / Projeção Orçamentária Ano a Ano (Recorrente)
      const meses = [
        { nome: 'Janeiro', num: 0 },
        { nome: 'Fevereiro', num: 1 },
        { nome: 'Março', num: 2 },
        { nome: 'Abril', num: 3 },
        { nome: 'Maio', num: 4 },
        { nome: 'Junho', num: 5 },
        { nome: 'Julho', num: 6 },
        { nome: 'Agosto', num: 7 },
        { nome: 'Setembro', num: 8 },
        { nome: 'Outubro', num: 9 },
        { nome: 'Novembro', num: 10 },
        { nome: 'Dezembro', num: 11 }
      ];

      const corpoTabela = document.getElementById('corpo-tabela-anos');
      corpoTabela.innerHTML = '';
      
      const valorBaseLocal = parseFloat('<%= valorBase %>') || 600.00;

      // Calcular despesas baseando-se no mês atual da data do sistema
      const hojeSis = new Date();
      const mesAtualSis = hojeSis.getMonth();

      function calcularDiferencaMeses(d1, d2) {
        return (d2.getFullYear() - d1.getFullYear()) * 12 + (d2.getMonth() - d1.getMonth());
      }

      meses.forEach(m => {
        // Cálculo de pagamentos ativos com limite estrito de 12 meses de vigência (anos 2026, 2027, 2028)
        const aptos2026 = dbProcessos.filter(p => {
          if (p.statusAtual !== 'APTO_PAGAMENTO') return false;
          const criacao = new Date(p.dataCriacao);
          const criacaoMes = new Date(criacao.getFullYear(), criacao.getMonth(), 1);
          const refDate = new Date(2026, m.num, 1);
          const diff = calcularDiferencaMeses(criacaoMes, refDate);
          return diff >= 0 && diff < 12;
        });

        const aptos2027 = dbProcessos.filter(p => {
          if (p.statusAtual !== 'APTO_PAGAMENTO') return false;
          const criacao = new Date(p.dataCriacao);
          const criacaoMes = new Date(criacao.getFullYear(), criacao.getMonth(), 1);
          const refDate = new Date(2027, m.num, 1);
          const diff = calcularDiferencaMeses(criacaoMes, refDate);
          return diff >= 0 && diff < 12;
        });

        const aptos2028 = dbProcessos.filter(p => {
          if (p.statusAtual !== 'APTO_PAGAMENTO') return false;
          const criacao = new Date(p.dataCriacao);
          const criacaoMes = new Date(criacao.getFullYear(), criacao.getMonth(), 1);
          const refDate = new Date(2028, m.num, 1);
          const diff = calcularDiferencaMeses(criacaoMes, refDate);
          return diff >= 0 && diff < 12;
        });

        let valor2026 = aptos2026.length * valorBaseLocal;
        let valor2027 = aptos2027.length * valorBaseLocal;
        let valor2028 = aptos2028.length * valorBaseLocal;

        // Se o mês for futuro em 2026, destacar como planejado/projetado
        const isFuturo = m.num > mesAtualSis;
        const textoEstilo2026 = isFuturo 
          ? `color: var(--text-muted); font-style: italic;` 
          : `font-weight: 700; color: var(--primary);`;

        const crescimento = valor2026 > 0 ? (((valor2027 - valor2026) / valor2026) * 100).toFixed(1) + '%' : '0.0%';
        const growsUp = parseFloat(crescimento) >= 0;
        
        corpoTabela.innerHTML += `
          <tr>
            <td><strong>${m.nome}</strong></td>
            <td class="text-right" style="${textoEstilo2026}">
              R$ ${valor2026.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
              ${isFuturo ? ' <span style="font-size:0.65rem; font-weight:700; text-transform:uppercase; background:#f1f5f9; padding:2px 4px; border-radius:3px;">Proj</span>' : ''}
            </td>
            <td class="text-right" style="color: var(--text-main); font-weight: 600;">R$ ${valor2027.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
            <td class="text-right" style="color: var(--text-muted);">R$ ${valor2028.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
            <td class="text-right" style="font-weight: 700; color: ${growsUp ? 'var(--success)' : 'var(--danger)'};">${growsUp ? '▲' : '▼'} ${crescimento}</td>
          </tr>
        `;
      });

      // E. Idades
      const cIdades = document.getElementById('chart-idades');
      cIdades.innerHTML = '';
      if (!data.distribuicaoIdade || data.distribuicaoIdade.length === 0) {
        cIdades.innerHTML = '<p style="color: var(--text-muted); text-align: center;">Sem dados demográficos.</p>';
      } else {
        const maxIdade = Math.max(...data.distribuicaoIdade.map(i => i.quantidade));
        data.distribuicaoIdade.forEach(i => {
          const perc = maxIdade > 0 ? (i.quantidade / maxIdade) * 100 : 0;
          cIdades.innerHTML += `
            <div class="bar-row" style="display: flex; align-items: center; gap: 1rem;">
              <span style="font-size: 0.85rem; width: 120px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${i.faixa}</span>
              <div style="flex-grow: 1; height: 12px; background: #e2e8f0; border-radius: 6px; overflow: hidden;">
                <div style="width: ${perc}%; height: 100%; background: var(--secondary); transition: width 0.5s ease;"></div>
              </div>
              <span style="font-size: 0.85rem; font-weight: 600; width: 30px; text-align: right;">${i.quantidade}</span>
            </div>
          `;
        });
      }

      // F. Esteiras
      const cEsteiras = document.getElementById('chart-esteiras');
      cEsteiras.innerHTML = '';
      if (!data.distribuicaoEsteira || data.distribuicaoEsteira.length === 0) {
        cEsteiras.innerHTML = '<p style="color: var(--text-muted); text-align: center;">Sem dados de esteira.</p>';
      } else {
        const maxEsteira = Math.max(...data.distribuicaoEsteira.map(e => e.quantidade));
        data.distribuicaoEsteira.forEach(e => {
          const perc = maxEsteira > 0 ? (e.quantidade / maxEsteira) * 100 : 0;
          cEsteiras.innerHTML += `
            <div class="bar-row" style="display: flex; align-items: center; gap: 1rem;">
              <span style="font-size: 0.85rem; width: 120px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${e.esteira}</span>
              <div style="flex-grow: 1; height: 12px; background: #e2e8f0; border-radius: 6px; overflow: hidden;">
                <div style="width: ${perc}%; height: 100%; background: var(--primary); transition: width 0.5s ease;"></div>
              </div>
              <span style="font-size: 0.85rem; font-weight: 600; width: 30px; text-align: right;">${e.quantidade}</span>
            </div>
          `;
        });
      }

      // G. Evolução Mensal de Novos Requerimentos (Filtrável por Ano)
      if (!window.selectedEvolucaoAno) {
        window.selectedEvolucaoAno = '2026';
      }

      const selectEvolucaoEl = document.getElementById('filtro-ano-evolucao');
      if (selectEvolucaoEl) {
        selectEvolucaoEl.value = window.selectedEvolucaoAno;
      }

      const anoEvolucao = parseInt(window.selectedEvolucaoAno, 10);
      const mesesOrdenados = [];
      for (let m = 0; m < 12; m++) {
        mesesOrdenados.push({
          label: nomeMeses[m].substring(0,3) + '/' + anoEvolucao,
          num: m,
          ano: anoEvolucao
        });
      }

      const cMensal = document.getElementById('chart-mensal');
      cMensal.innerHTML = '';

      let maxCount = 0;
      const dadosGrafico = mesesOrdenados.map(m => {
        const doMes = dbProcessos.filter(p => {
          const d = new Date(p.dataCriacao);
          return d.getFullYear() === m.ano && d.getMonth() === m.num;
        });
        const solicitados = doMes.length;
        const aprovados = doMes.filter(p => ['APROVADO', 'APTO_PAGAMENTO'].includes(p.statusAtual)).length;

        if (solicitados > maxCount) maxCount = solicitados;
        return { label: m.label, solicitados, aprovados };
      });

      dadosGrafico.forEach(d => {
        const percSol = maxCount > 0 ? (d.solicitados / maxCount) * 100 : 0;
        const percApr = maxCount > 0 ? (d.aprovados / maxCount) * 100 : 0;

        cMensal.innerHTML += `
          <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.85rem;">
            <span style="font-size: 0.85rem; width: 90px; font-weight: 600; color: var(--text-main);">${d.label}</span>
            <div style="flex-grow: 1; display: flex; flex-direction: column; gap: 4px;">
              <!-- Solicitados (Azul MDS) -->
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <div style="flex-grow: 1; height: 10px; background: #e2e8f0; border-radius: 5px; overflow: hidden;">
                  <div style="width: ${percSol}%; height: 100%; background: var(--primary); transition: width 0.5s;"></div>
                </div>
                <span style="font-size: 0.75rem; font-weight: 700; color: var(--primary); width: 60px;">${d.solicitados} Solic.</span>
              </div>
              <!-- Aprovados (Verde SUAS) -->
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <div style="flex-grow: 1; height: 10px; background: #e2e8f0; border-radius: 5px; overflow: hidden;">
                  <div style="width: ${percApr}%; height: 100%; background: var(--success); transition: width 0.5s;"></div>
                </div>
                <span style="font-size: 0.75rem; font-weight: 700; color: var(--success); width: 60px;">${d.aprovados} Aprov.</span>
              </div>
            </div>
          </div>
        `;
      });

      // H. Alertas de Renovação Pendente (≤ 60 dias para completar 12 meses)
      const cRenovacao = document.getElementById('alertas-renovacao-container');
      const corpoTabelaRenovacao = document.getElementById('corpo-tabela-renovacao');
      const bubbleCountRenovacao = document.getElementById('count-renovacao');
      
      const hoje = new Date();
      const expirando = dbProcessos.filter(p => {
        if (p.statusAtual !== 'APTO_PAGAMENTO') return false;
        const criacao = new Date(p.dataCriacao);
        
        // Fim da vigência de 12 meses
        const dataFim = new Date(criacao);
        dataFim.setMonth(dataFim.getMonth() + 12);
        
        const diffMs = dataFim - hoje;
        const diffDays = Math.ceil(diffMs / (1000 * 60 * 60 * 24));
        
        // Expira nos próximos 60 dias
        return diffDays > 0 && diffDays <= 60;
      });

      // Atualiza a bolha de contagem na aba superior
      if (bubbleCountRenovacao) {
        bubbleCountRenovacao.textContent = expirando.length;
      }

      // Popula a barra lateral resumida no Painel Geral
      if (cRenovacao) {
        if (expirando.length === 0) {
          cRenovacao.innerHTML = `
            <p style="color: var(--text-muted); font-size: 0.85rem; font-style: italic; text-align: center; margin: 0; padding: 0.75rem;">
              Nenhum benefício requer renovação nos próximos 60 dias.
            </p>
          `;
        } else {
          cRenovacao.innerHTML = '';
          expirando.forEach(p => {
            const criacao = new Date(p.dataCriacao);
            const dataFim = new Date(criacao);
            dataFim.setMonth(dataFim.getMonth() + 12);
            const diffMs = dataFim - hoje;
            const diffDays = Math.ceil(diffMs / (1000 * 60 * 60 * 24));

            cRenovacao.innerHTML += `
              <div style="background-color: #fffbeb; border: 1px solid #fef3c7; border-left: 4px solid #d97706; padding: 0.75rem; border-radius: 4px; display: flex; flex-direction: column; gap: 4px; text-align: left;">
                <div style="display:flex; justify-content:space-between; align-items:center; gap: 1rem;">
                  <strong style="font-size: 0.85rem; color: #b45309; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${p.beneficiaria.nome}</strong>
                  <span style="font-size: 0.7rem; font-weight:700; background:#fef3c7; color:#b45309; padding:2px 6px; border-radius:3px; white-space: nowrap;">
                    ${diffDays} dias rest.
                  </span>
                </div>
                <div style="display:flex; justify-content:space-between; font-size: 0.75rem; color: var(--text-muted);">
                  <span>SEI: ${p.numeroProcessoSei}</span>
                  <span>Expira: ${dataFim.toLocaleDateString('pt-BR')}</span>
                </div>
              </div>
            `;
          });
        }
      }

      // Popula a tabela detalhada na nova subaba dedicada
      if (corpoTabelaRenovacao) {
        if (expirando.length === 0) {
          corpoTabelaRenovacao.innerHTML = `
            <tr>
              <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 3rem;">
                Nenhum benefício ativo requer renovação nos próximos 60 dias.
              </td>
            </tr>
          `;
        } else {
          corpoTabelaRenovacao.innerHTML = '';
          expirando.forEach(p => {
            const criacao = new Date(p.dataCriacao);
            const dataFim = new Date(criacao);
            dataFim.setMonth(dataFim.getMonth() + 12);
            const diffMs = dataFim - hoje;
            const diffDays = Math.ceil(diffMs / (1000 * 60 * 60 * 24));

            corpoTabelaRenovacao.innerHTML += `
              <tr class="homologacao-row" style="cursor: pointer;" onclick="abrirDrawerFicha('${p.id}')">
                <td><strong>${p.numeroProcessoSei}</strong></td>
                <td>
                  <div class="confidential-wrapper" onclick="event.stopPropagation();">
                    <span class="confidential-data blurred">${p.beneficiaria.nome} (${p.beneficiaria.cpf})</span>
                    <button class="btn-toggle-sigilo" onclick="toggleSigilo(this)" title="Exibir/Ocultar Dados">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                      Exibir
                    </button>
                  </div>
                </td>
                <td>${criacao.toLocaleDateString('pt-BR')}</td>
                <td><strong class="text-danger">${dataFim.toLocaleDateString('pt-BR')}</strong></td>
                <td>
                  <span class="sla-badge red" style="font-weight: 700;">
                    ${diffDays} dias restantes
                  </span>
                </td>
                <td class="text-right" onclick="event.stopPropagation();">
                  <button class="btn-action-primary" onclick="abrirDrawerFicha('${p.id}')" style="padding: 0.35rem 0.75rem; font-size: 0.75rem;">
                    Iniciar Renovação
                  </button>
                </td>
              </tr>
            `;
          });
        }
      }

    } catch (error) {
      console.error('Estatísticas falharam:', error);
    }
  }

  function filtrarExplosaoMesAno() {
    const val = document.getElementById('filtro-mes-ano-explosao').value;
    window.selectedExplosaoPeriodo = val;
    carregarGraficosEstatisticos();
  }

  function filtrarEvolucaoAno() {
    const val = document.getElementById('filtro-ano-evolucao').value;
    window.selectedEvolucaoAno = val;
    carregarGraficosEstatisticos();
  }

  // --- EXPORTAR PLANILHA CSV ---
  function exportarDadosFinanceiros() {
    const table = document.getElementById('tabela-financeira-list');
    let csvContent = "data:text/csv;charset=utf-8,";
    csvContent += "Processo SEI,Nome,CPF,BancoInfo,Esteira,ValorBase\n";
    
    const rows = table.querySelectorAll('tbody tr');
    if (rows.length === 0) {
      alert("Nenhum dado financeiro apto para exportar.");
      return;
    }
    
    rows.forEach(row => {
      const cols = row.querySelectorAll('td');
      const sei = cols[0].innerText.trim();
      const nome = cols[1].innerText.trim();
      const cpf = cols[2].innerText.trim();
      const dadosBancarios = cols[3].innerText.replace(/,/g, '|').trim();
      const esteira = cols[4].innerText.trim();
      const valor = cols[5].innerText.replace("R$ ", "").trim();
      
      csvContent += `"${sei}","${nome}","${cpf}","${dadosBancarios}","${esteira}","${valor}"\n`;
    });
    
    const encodedUri = encodeURI(csvContent);
    const link = document.createElement("a");
    link.setAttribute("href", encodedUri);
    link.setAttribute("download", `folha_pagamento_${new Date().toISOString().substring(0,10)}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

  // Explicit window bindings
  window.abrirDrawerFicha = abrirDrawerFicha;
  window.fecharDrawerFicha = fecharDrawerFicha;
  window.switchGestorTab = switchGestorTab;
  window.filtrarAuditoria = filtrarAuditoria;
  window.pagAuditoriaAnt = pagAuditoriaAnt;
  window.pagAuditoriaProx = pagAuditoriaProx;
  window.alterarLimiteAuditoria = alterarLimiteAuditoria;
  
  window.filtrarHomologacao = filtrarHomologacao;
  window.pagHomologacaoAnt = pagHomologacaoAnt;
  window.pagHomologacaoProx = pagHomologacaoProx;
  window.alterarLimiteHomologacao = alterarLimiteHomologacao;
  window.homologarParaPagamento = homologarParaPagamento;
  window.exportarDadosFinanceiros = exportarDadosFinanceiros;
  window.filtrarExplosaoMesAno = filtrarExplosaoMesAno;
  window.filtrarEvolucaoAno = filtrarEvolucaoAno;
</script>

