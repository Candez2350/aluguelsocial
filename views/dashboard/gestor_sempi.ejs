    </div>
  </div>

  <!-- Tabela de Auditoria -->
  <div class="section-card">
    <div class="section-header">
      <h2 class="section-title">Auditoria e Monitoramento da Fila de Tramitação</h2>
    </div>
    <div class="section-content" style="padding: 0;">
      <div class="table-responsive">
        <table class="custom-table" id="tabela-auditoria-list">
          <thead>
            <tr>
              <th>Processo SEI</th>
              <th>Cidadã (CPF)</th>
              <th>Fase Atual</th>
              <th>Esteira</th>
              <th>Data Limite SLA</th>
              <th>Status do Prazo</th>
            </tr>
          </thead>
          <tbody>
            <% if (ativos.length === 0) { %>
              <tr class="sem-auditoria-row">
                <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 3rem;">
                  Nenhum processo em trâmite ativo.
                </td>
              </tr>
            <% } else { 
              const ativosOrdenados = [...ativos].sort((a,b) => new Date(a.dataLimiteAnalise) - new Date(b.dataLimiteAnalise));
              ativosOrdenados.forEach(p => {
                const limite = new Date(p.dataLimiteAnalise);
                const diffMs = limite - agora;
                const diffDays = Math.ceil(diffMs / (1000 * 60 * 60 * 24));
                
                let slaBadgeClass = 'green';
                let slaText = 'Em Dia';
                let slaDesc = `${diffDays} dias restantes`;
                
                if (diffDays < 0) {
                  slaBadgeClass = 'red';
                  slaText = 'Atrasado';
                  slaDesc = `Vencido há ${Math.abs(diffDays)} dias`;
                } else if (diffDays <= 2) {
                  slaBadgeClass = 'yellow';
                  slaText = 'Crítico';
                  slaDesc = `Vence em ${diffDays} dias`;
                }
            %>
              <tr class="auditoria-row" data-id="<%= p.id %>" data-sei="<%= p.numeroProcessoSei %>" data-nome="<%= p.beneficiaria.nome %>" data-cpf="<%= p.beneficiaria.cpf %>" data-status-sla="<%= diffDays < 0 ? 'ATRASADO' : 'EM_DIA' %>" style="cursor: pointer;" onclick="abrirDrawerFicha('<%= p.id %>')">
                <td><strong><%= p.numeroProcessoSei %></strong></td>
                <td>
                  <div class="confidential-wrapper" onclick="event.stopPropagation();">
                    <span class="confidential-data blurred"><%= p.beneficiaria.nome %> (<%= p.beneficiaria.cpf %>)</span>
                    <button class="btn-toggle-sigilo" onclick="toggleSigilo(this)" title="Exibir/Ocultar Dados">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                      Exibir
                    </button>
                  </div>
                </td>
                <td>
                  <span class="status-tag <%= p.statusAtual.toLowerCase() %>">
                    <%= p.statusAtual %>
                  </span>
                </td>
                <td>
                  <span class="esteira-tag <%= p.tipoEsteira.toLowerCase() %>">
                    <%= p.tipoEsteira %>
                  </span>
                </td>
                <td><strong><%= limite.toLocaleDateString('pt-BR') %></strong></td>
                <td>
                  <span class="sla-badge <%= slaBadgeClass %>">
                    <%= slaText %> (<%= slaDesc %>)
                  </span>
                </td>
              </tr>
            <% }) %>
          <% } %>
          </tbody>
        </table>
      </div>

      <!-- Paginação Auditoria -->
      <div class="pagination-container">
        <div class="pagination-select-wrapper">
          <span>Itens por página:</span>
          <select class="pagination-select" id="limit-tabela-auditoria-list" onchange="alterarLimiteAuditoria()">
            <option value="5" selected>5</option>
            <option value="10">10</option>
            <option value="15">15</option>
          </select>
