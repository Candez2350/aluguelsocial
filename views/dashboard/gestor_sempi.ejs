<!-- Dados brutos serializados -->
<textarea id="processos-raw-data" style="display: none;"><%- JSON.stringify(processos) %></textarea>

<script>
  const dbProcessos = JSON.parse(document.getElementById('processos-raw-data').value);

  // Estados locais das abas e paginações
  const auditoriaPag = { pag: 1, limit: 5 };
  const homologacaoPag = { pag: 1, limit: 5 };

  document.addEventListener('DOMContentLoaded', () => {
    carregarGraficosEstatisticos();
    
    inicializarAtributosTabela('tabela-auditoria-list', 'auditoria-row');
    inicializarAtributosTabela('tabela-homologacao-list', 'homologacao-row');
    
    aplicarPaginacaoAuditoria();
    aplicarPaginacaoHomologacao();
  });

  function switchGestorTab(tabName) {
    document.querySelectorAll('.tab-panel-content').forEach(panel => {
      panel.style.display = 'none';
    });
    document.querySelectorAll('.tabs-container .tab-btn').forEach(btn => {
      btn.classList.remove('active');
    });

    document.getElementById(`tab-content-${tabName}`).style.display = 'block';
    document.getElementById(`tab-btn-${tabName}`).classList.add('active');
  }

  function inicializarAtributosTabela(tableId, rowClass) {
    document.querySelectorAll(`#${tableId} .${rowClass}`).forEach(row => {
      row.setAttribute('data-filtered-out', 'false');
    });
  }

  // --- CONTROLES FILA DE AUDITORIA ---
  function filtrarAuditoria() {
    const q = document.getElementById('busca-auditoria').value.toLowerCase().trim();
    const sla = document.getElementById('filtro-sla-auditoria').value;
    
    const rows = document.querySelectorAll('#tabela-auditoria-list .auditoria-row');
    rows.forEach(row => {
      const sei = row.getAttribute('data-sei').toLowerCase();
      const nome = row.getAttribute('data-nome').toLowerCase();
      const cpf = row.getAttribute('data-cpf').toLowerCase();
      const statusSla = row.getAttribute('data-status-sla');
      
      const matchText = sei.includes(q) || nome.includes(q) || cpf.includes(q);
      const matchSla = sla === 'TODOS' || statusSla === sla;
      
      if (matchText && matchSla) {
        row.setAttribute('data-filtered-out', 'false');
      } else {
        row.setAttribute('data-filtered-out', 'true');
      }
    });

    auditoriaPag.pag = 1;
    aplicarPaginacaoAuditoria();
  }

  function aplicarPaginacaoAuditoria() {
    const tableId = 'tabela-auditoria-list';
    const rows = Array.from(document.querySelectorAll(`#${tableId} .auditoria-row`));
    const filteredRows = rows.filter(row => row.getAttribute('data-filtered-out') !== 'true');
    
    const total = filteredRows.length;
    const limit = auditoriaPag.limit;
    const totalPages = Math.max(1, Math.ceil(total / limit));
    
    if (auditoriaPag.pag > totalPages) auditoriaPag.pag = totalPages;
    if (auditoriaPag.pag < 1) auditoriaPag.pag = 1;
    
    const start = (auditoriaPag.pag - 1) * limit;
    const end = Math.min(start + limit, total);
    
    rows.forEach(row => row.style.display = 'none');
    filteredRows.slice(start, end).forEach(row => row.style.display = '');

    const info = document.getElementById(`info-${tableId}`);
    if (info) {
      info.textContent = total === 0 ? 'Nenhum processo na fila de auditoria' : `Exibindo ${start + 1}-${end} de ${total} em andamento`;
    }

    document.getElementById(`btn-prev-${tableId}`).disabled = auditoriaPag.pag === 1;
    document.getElementById(`btn-next-${tableId}`).disabled = auditoriaPag.pag === totalPages;
  }

  function pagAuditoriaAnt() {
    if (auditoriaPag.pag > 1) {
      auditoriaPag.pag--;
      aplicarPaginacaoAuditoria();
    }
  }

  function pagAuditoriaProx() {
    const rows = Array.from(document.querySelectorAll('#tabela-auditoria-list .auditoria-row'));
    const filteredRows = rows.filter(row => row.getAttribute('data-filtered-out') !== 'true');
    const totalPages = Math.ceil(filteredRows.length / auditoriaPag.limit);
    if (auditoriaPag.pag < totalPages) {
      auditoriaPag.pag++;
      aplicarPaginacaoAuditoria();
    }
  }

  function alterarLimiteAuditoria() {
    auditoriaPag.limit = parseInt(document.getElementById('limit-tabela-auditoria-list').value, 10);
    auditoriaPag.pag = 1;
    aplicarPaginacaoAuditoria();
  }

  // --- CONTROLES FILA DE HOMOLOGAÇÃO ---
  function filtrarHomologacao() {
    const q = document.getElementById('busca-homologacao').value.toLowerCase().trim();
    
    const rows = document.querySelectorAll('#tabela-homologacao-list .homologacao-row');
    rows.forEach(row => {
      const sei = row.getAttribute('data-sei').toLowerCase();
      const nome = row.getAttribute('data-nome').toLowerCase();
      const cpf = row.getAttribute('data-cpf').toLowerCase();
      
      const matchText = sei.includes(q) || nome.includes(q) || cpf.includes(q);
      
      if (matchText) {
        row.setAttribute('data-filtered-out', 'false');
      } else {
        row.setAttribute('data-filtered-out', 'true');
      }
    });

    homologacaoPag.pag = 1;
    aplicarPaginacaoHomologacao();
  }

  function aplicarPaginacaoHomologacao() {
    const tableId = 'tabela-homologacao-list';
    const rows = Array.from(document.querySelectorAll(`#${tableId} .homologacao-row`));
    const filteredRows = rows.filter(row => row.getAttribute('data-filtered-out') !== 'true');
    
    const total = filteredRows.length;
    const limit = homologacaoPag.limit;
    const totalPages = Math.max(1, Math.ceil(total / limit));
    
    if (homologacaoPag.pag > totalPages) homologacaoPag.pag = totalPages;
    if (homologacaoPag.pag < 1) homologacaoPag.pag = 1;
    
    const start = (homologacaoPag.pag - 1) * limit;
    const end = Math.min(start + limit, total);
    
    rows.forEach(row => row.style.display = 'none');
    filteredRows.slice(start, end).forEach(row => row.style.display = '');

    const info = document.getElementById(`info-${tableId}`);
    if (info) {
      info.textContent = total === 0 ? 'Nenhum processo aguardando homologação' : `Exibindo ${start + 1}-${end} de ${total} aguardando homologação`;
    }

    document.getElementById(`btn-prev-${tableId}`).disabled = homologacaoPag.pag === 1;
    document.getElementById(`btn-next-${tableId}`).disabled = homologacaoPag.pag === totalPages;
  }

  function pagHomologacaoAnt() {
    if (homologacaoPag.pag > 1) {
      homologacaoPag.pag--;
      aplicarPaginacaoHomologacao();
    }
  }

  function pagHomologacaoProx() {
    const rows = Array.from(document.querySelectorAll('#tabela-homologacao-list .homologacao-row'));
    const filteredRows = rows.filter(row => row.getAttribute('data-filtered-out') !== 'true');
    const totalPages = Math.ceil(filteredRows.length / homologacaoPag.limit);
    if (homologacaoPag.pag < totalPages) {
      homologacaoPag.pag++;
      aplicarPaginacaoHomologacao();
    }
  }

  function alterarLimiteHomologacao() {
    homologacaoPag.limit = parseInt(document.getElementById('limit-tabela-homologacao-list').value, 10);
    homologacaoPag.pag = 1;
    aplicarPaginacaoHomologacao();
  }

  async function homologarParaPagamento(id) {
    const confirmacao = confirm("Deseja realmente homologar este requerimento aprovado e liberá-lo para a folha de pagamento ativa?");
    if (!confirmacao) return;

    try {
      const response = await fetch(`/api/processos/${id}/status`, {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ status: 'APTO_PAGAMENTO' })
      });
      
      const res = await response.json();
      if (res.success) {
        fecharDrawerFicha();
        window.location.reload();
      } else {
        mostrarAlerta('danger', res.error);
      }
    } catch (error) {
      mostrarAlerta('danger', 'Erro ao homologar processo.');
    }
  }

  // --- DRAWER DE DETALHES DO GESTOR ---
  function abrirDrawerFicha(id) {
    const p = dbProcessos.find(proc => proc.id === id);
    if (!p) return;

    document.getElementById('drawer-header-title').textContent = `Processo SEI: ${p.numeroProcessoSei}`;

    let dadosBancarios = { banco: 'Não Cadastrado', agencia: 'N/A', conta: 'N/A' };
    try {
      if (p.beneficiaria.dadosBancariosManuais) {
        dadosBancarios = JSON.parse(p.beneficiaria.dadosBancariosManuais);
      }
    } catch(e){}

    const content = document.getElementById('drawer-ficha-content');
    content.innerHTML = `
      <!-- Situação -->
      <div class="drawer-section">
        <div class="drawer-section-title">Situação do Requerimento</div>
        <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
          <span class="status-tag ${p.statusAtual.toLowerCase()}" style="font-size: 0.85rem; padding: 0.4rem 0.8rem;">
            ${p.statusAtual}
          </span>
          <span class="esteira-tag ${p.tipoEsteira.toLowerCase()}" style="font-size: 0.8rem; padding: 0.35rem 0.7rem;">
            Esteira ${p.tipoEsteira}
          </span>
        </div>
      </div>

      <!-- Beneficiária -->
      <div class="drawer-section">
        <div class="drawer-section-title">Perfil da Beneficiária</div>
        <div class="drawer-grid">
          <div class="drawer-item full-width">
            <span class="drawer-label">Nome Completo</span>
            <div class="confidential-wrapper">
