<%- include('../partials/header') %>

<div id="gestor-alert-container"></div>

<!-- Pré-cálculos Estatísticos & Métricas para Alta Liderança -->
<%
  const agora = new Date();
  
  // 1. Processos ativos nas esteiras (Triagem, Análise e Recurso)
  const ativos = processos.filter(p => ['TRIAGEM', 'ANALISE', 'RECURSO'].includes(p.statusAtual));
  
  // 2. Processos aprovados aguardando homologação do gestor
  const aprovados = processos.filter(p => p.statusAtual === 'APROVADO');
  
  // 3. Processos aptos para pagamento (Folha Ativa)
  const aptos = processos.filter(p => p.statusAtual === 'APTO_PAGAMENTO');
  
  // 4. Processos da esteira Simplificada (Judicial / MPU) ativos
  const prioridadeJudicial = processos.filter(p => p.tipoEsteira === 'SIMPLIFICADO' && ['ANALISE', 'RECURSO'].includes(p.statusAtual)).length;
  
  // 5. Processos atrasados (SLA de análise estourado)
  const atrasados = ativos.filter(p => new Date(p.dataLimiteAnalise) < agora);
  
  // 6. Taxa de conformidade de SLA (%)
  const taxaSla = ativos.length > 0 ? (((ativos.length - atrasados.length) / ativos.length) * 100).toFixed(1) : "100.0";
  
  // 7. Impacto Orçamentário
  const custoMensal = aptos.length * valorBase;
  const custoAnualProjetado = custoMensal * 12;
%>

<!-- ================= SEÇÃO 1: PAINEL DE KPIs EXECUTIVOS ================= -->
<div class="metrics-grid">
  <!-- Card 1: Impacto Financeiro (Azul Royal) -->
  <div class="metric-card primary">
    <div class="metric-title">Folha Mensal Ativa</div>
    <div class="metric-value" style="font-size: 1.8rem; color: var(--primary);">
      R$ <%= custoMensal.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
    </div>
    <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 6px; font-weight: 500;">
      Projeção Anual: R$ <%= custoAnualProjetado.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
    </div>
  </div>

  <!-- Card 2: Homologações Pendentes (Laranja Lacre) -->
  <div class="metric-card secondary">
    <div class="metric-title">Pendente Homologação</div>
    <div class="metric-value" style="font-size: 1.8rem; color: var(--secondary);">
      <%= aprovados.length %> <span style="font-size: 1rem; font-weight: 500; color: var(--text-muted);">processos</span>
    </div>
    <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 6px; font-weight: 500;">
      Aguardando liberação de folha
    </div>
  </div>

  <!-- Card 3: Conformidade de SLA (Verde Esmeralda) -->
  <div class="metric-card success">
    <div class="metric-title">Eficiência de SLA</div>
    <div class="metric-value" style="font-size: 1.8rem; color: var(--success);">
      <%= taxaSla %>%
    </div>
    <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 6px; font-weight: 500;">
      <%= atrasados.length %> processos em atraso
    </div>
  </div>

  <!-- Card 4: Backlog de Fila (Tons Neutros / Slate) -->
  <div class="metric-card">
    <div class="metric-title">Esteira em Trâmite</div>
    <div class="metric-value" style="font-size: 1.8rem; color: var(--text-main);">
      <%= ativos.length %> <span style="font-size: 1rem; font-weight: 500; color: var(--text-muted);">ativos</span>
    </div>
    <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 6px; font-weight: 500;">
      Judiciais ativos: <%= prioridadeJudicial %>
    </div>
  </div>
</div>

<!-- ================= SEÇÃO 2: ABAS DE CONTROLE ESTRATÉGICO ================= -->
<div class="controls-row" style="margin-bottom: 2rem;">
  <div class="tabs-container" style="display: flex; flex-wrap: nowrap; overflow-x: auto; gap: 0.25rem; padding: 0.25rem;">
    <button id="tab-btn-resumo" class="tab-btn active" onclick="switchGestorTab('resumo')">
      Painel Geral
    </button>
    <button id="tab-btn-homologar" class="tab-btn" onclick="switchGestorTab('homologar')">
      Homologar <span id="count-homologar" class="badge-bubble"><%= aprovados.length %></span>
    </button>
    <button id="tab-btn-financeira" class="tab-btn" onclick="switchGestorTab('financeira')">
      Folha <span id="count-financeira" class="badge-bubble"><%= aptos.length %></span>
    </button>
    <button id="tab-btn-orcamento" class="tab-btn" onclick="switchGestorTab('orcamento')">
      Orçamento
    </button>
    <button id="tab-btn-renovacao" class="tab-btn" onclick="switchGestorTab('renovacao')">
      Renovações <span id="count-renovacao" class="badge-bubble">0</span>
    </button>
    <button id="tab-btn-distribuicao" class="tab-btn" onclick="switchGestorTab('distribuicao')">
      Mapeamento
    </button>
    <button id="tab-btn-auditoria" class="tab-btn" onclick="switchGestorTab('auditoria')">
      Gargalos <span id="count-auditoria" class="badge-bubble"><%= ativos.length %></span>
    </button>
  </div>
</div>

<!-- ================= ABA 1: PAINEL GERAL (RESUMO ESTRATÉGICO) ================= -->
<div id="tab-content-resumo" class="tab-panel-content">
  <div class="dashboard-grid">
    <!-- Bloco Esquerdo: Monitoramento e Prazos -->
    <div>
      <div class="section-card">
        <div class="section-header">
          <h2 class="section-title">Acompanhamento e Gestão Orçamentária</h2>
        </div>
        <div class="section-content">
          <p style="color: var(--text-muted); line-height: 1.6; margin-bottom: 1.5rem; font-size: 0.95rem;">
            O painel orçamentário do Aluguel Social permite o controle executivo de desembolsos em tempo real. Toda concessão de benefício aprovada pelas equipes do SUAS ou SEDSODH deve ser homologada nesta página para integrar a folha de pagamento.
          </p>

          <div class="dashboard-form-grid" style="margin-top: 1rem;">
            <div style="background-color: var(--primary-light); border: 1.5px solid rgba(30, 58, 138, 0.1); border-radius: var(--radius-md); padding: 1.25rem; display: flex; flex-direction: column; justify-content: space-between; min-height: 120px;">
              <span style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--primary); letter-spacing: 0.5px; display: block; margin-bottom: 4px;">Valor Unitário Portaria</span>
              <strong style="font-size: 1.65rem; color: var(--primary); font-family: var(--font-title); display: block; margin-top: auto; margin-bottom: auto;">R$ <%= valorBase.toFixed(2) %></strong>
              <span style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-top: 4px;">Fixado por ato executivo municipal</span>
            </div>
            
            <div style="background-color: var(--bg-app); border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 1.25rem; display: flex; flex-direction: column; justify-content: space-between; min-height: 120px;">
              <span style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.5px; display: block; margin-bottom: 4px;">Total de Processos</span>
              <strong style="font-size: 1.65rem; color: var(--text-main); font-family: var(--font-title); display: block; margin-top: auto; margin-bottom: auto;"><%= estatisticas.total %></strong>
              <span style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-top: 4px;">Histórico acumulado do programa</span>
            </div>
          </div>

          <div style="margin-top: 2rem; border-top: 1px dashed var(--border-color); padding-top: 1.5rem;">
            <h3 style="font-family: var(--font-title); font-size: 1rem; color: var(--primary); margin-bottom: 0.5rem;">
              Auditoria de Backlog e Gargalos
            </h3>
            <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.5;">
              <% if (atrasados.length > 0) { %>
                Atenção: Constam <strong class="text-danger"><%= atrasados.length %> processos fora do prazo regulamentar</strong> nas filas de análise. Recomenda-se acompanhamento imediato das equipes de triagem para evitar passivos processuais.
              <% } else { %>
                Excelente: <strong class="text-success">100% dos processos ativos estão com prazos de análise regulamentares em dia</strong>. Fila operacional fluida e livre de atrasos.
              <% } %>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Bloco Direito: Detalhamento Fila Geral (Composição de Status) -->
    <div>
      <div class="section-card">
        <div class="section-header">
          <h2 class="section-title">Composição da Fila Geral</h2>
        </div>
        <div class="section-content" style="padding: 1.5rem 2rem;">
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.85rem;">
            <li style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">
              <span style="font-size: 0.9rem; font-weight: 500;">Em Elaboração (Rascunho)</span>
              <span class="status-tag rascunho" style="font-size:0.7rem;"><%= processos.filter(p => p.statusAtual === 'RASCUNHO').length %></span>
            </li>
            <li style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">
              <span style="font-size: 0.9rem; font-weight: 500;">Aguardando Triagem</span>
              <span class="status-tag triagem" style="font-size:0.7rem;"><%= processos.filter(p => p.statusAtual === 'TRIAGEM').length %></span>
            </li>
            <li style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">
              <span style="font-size: 0.9rem; font-weight: 500;">Em Análise Técnico/Social</span>
              <span class="status-tag analise" style="font-size:0.7rem;"><%= processos.filter(p => p.statusAtual === 'ANALISE').length %></span>
            </li>
            <li style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">
              <span style="font-size: 0.9rem; font-weight: 500;">Deferidos Técnicos (Homologação)</span>
              <span class="status-tag aprovado" style="font-size:0.7rem;"><%= estatisticas.aprovado %></span>
            </li>
            <li style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">
              <span style="font-size: 0.9rem; font-weight: 500;">Aptos para Pagamento</span>
              <span class="status-tag apto_pagamento" style="font-size:0.7rem;"><%= estatisticas.aptoPagamento %></span>
            </li>
            <li style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">
              <span style="font-size: 0.9rem; font-weight: 500;">Recursos Administrativos</span>
              <span class="status-tag recurso" style="font-size:0.7rem;"><%= processos.filter(p => p.statusAtual === 'RECURSO').length %></span>
            </li>
            <li style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">
              <span style="font-size: 0.9rem; font-weight: 500;">Indeferidos Definitivos</span>
              <span class="status-tag indeferido" style="font-size:0.7rem;"><%= estatisticas.indeferido %></span>
            </li>
            <li style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 4px;">
              <span style="font-size: 0.9rem; font-weight: 500;">Benefícios Suspensos</span>
              <span class="status-tag suspenso" style="font-size:0.7rem;"><%= processos.filter(p => p.statusAtual === 'SUSPENSO').length %></span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Alertas de Renovação Pendente (Vencendo em até 60 dias) -->
      <div class="section-card" style="margin-top: 1.5rem;">
        <div class="section-header" style="background-color: #fff7ed; border-bottom: 1px solid #ffedd5;">
          <h2 class="section-title" style="color: #c2410c; margin: 0;">⚠️ Alertas de Renovação (≤ 60 dias)</h2>
        </div>
        <div class="section-content" style="padding: 1.25rem 1.5rem;">
          <div id="alertas-renovacao-container" style="display: flex; flex-direction: column; gap: 0.75rem;">
            <p style="color: var(--text-muted); font-size: 0.85rem; font-style: italic; text-align: center; margin: 0; padding: 0.75rem;">
              Nenhum benefício requer renovação imediata nos próximos 60 dias.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ================= ABA 2: HOMOLOGAÇÃO DE PROCESSOS APROVADOS ================= -->
<div id="tab-content-homologar" class="tab-panel-content" style="display: none;">
  <div class="controls-row">
    <div class="search-container" style="min-width: 320px;">
      <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input type="text" id="busca-homologacao" class="search-input" placeholder="Buscar por SEI ou Cidadã..." onkeyup="filtrarHomologacao()">
    </div>
  </div>

  <div class="section-card">
    <div class="section-header">
      <h2 class="section-title">Aguardando Homologação Financeira e Inclusão em Folha</h2>
    </div>
    <div class="section-content" style="padding: 0;">
      <div class="table-responsive">
        <table class="custom-table" id="tabela-homologacao-list">
          <thead>
            <tr class="bg-slate-50 text-slate-500 font-semibold text-xs tracking-wider uppercase border-b border-slate-200">
              <th>Processo SEI</th>
              <th>Cidadã (CPF)</th>
              <th>Origem</th>
              <th>Status Técnico</th>
              <th>Data Homologação</th>
              <th class="text-right">Ação Financeira</th>
            </tr>
          </thead>
          <tbody>
            <% if (aprovados.length === 0) { %>
              <tr class="sem-homologacao-row">
                <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 3rem;">
                  Nenhum processo aprovado pendente de homologação financeira.
                </td>
              </tr>
            <% } else { %>
              <% aprovados.forEach(p => { %>
                <tr class="homologacao-row" data-id="<%= p.id %>" data-sei="<%= p.numeroProcessoSei %>" data-nome="<%= p.beneficiaria.nome %>" data-cpf="<%= p.beneficiaria.cpf %>" style="cursor: pointer;" onclick="abrirDrawerFicha('<%= p.id %>')">
                  <td><strong><%= p.numeroProcessoSei %></strong></td>
                  <td>
                    <div class="confidential-wrapper" onclick="event.stopPropagation();">
                      <span class="confidential-data blurred"><%= p.beneficiaria.nome %> (<%= p.beneficiaria.cpf %>)</span>
                      <button class="btn-toggle-sigilo" onclick="toggleSigilo(this)" title="Exibir/Ocultar Dados">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        Exibir
                      </button>
                    </div>
                  </td>
                  <td>
                    <span class="esteira-tag <%= p.tipoEsteira.toLowerCase() %>">
                      Esteira <%= p.tipoEsteira %>
                    </span>
                  </td>
                  <td>
                    <span class="status-tag aprovado">
                      <%= p.statusAtual %>
                    </span>
                  </td>
                  <td><%= new Date(p.dataLimiteAnalise).toLocaleDateString('pt-BR') %></td>
                  <td class="text-right">
                    <div class="action-btn-group flex gap-2 justify-end" onclick="event.stopPropagation();">
                      <button class="btn-action-primary" onclick="homologarParaPagamento('<%= p.id %>')">
                        Homologar Pagamento
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
      
      <!-- Paginação Homologação -->
      <div class="pagination-container">
        <div class="pagination-select-wrapper">
          <span>Itens por página:</span>
          <select class="pagination-select" id="limit-tabela-homologacao-list" onchange="alterarLimiteHomologacao()">
            <option value="5" selected>5</option>
            <option value="10">10</option>
            <option value="15">15</option>
          </select>
        </div>
        <div class="pagination-info" id="info-tabela-homologacao-list">
          Exibindo 0-0 de 0 processos
        </div>
        <div class="pagination-controls">
          <button class="pagination-btn" id="btn-prev-tabela-homologacao-list" onclick="pagHomologacaoAnt()">Ant.</button>
          <button class="pagination-btn" id="btn-next-tabela-homologacao-list" onclick="pagHomologacaoProx()">Próx.</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ================= ABA 3: FILA FINANCEIRA (PAGAMENTOS) ================= -->
<div id="tab-content-financeira" class="tab-panel-content" style="display: none;">
  <!-- Seção de Exportação da Folha Financeira -->
  <div class="bg-white border border-slate-200 shadow-sm rounded-xl p-8 max-w-3xl mx-auto my-6 text-center">
    <div class="w-16 h-16 rounded-full bg-blue-50 border border-blue-100 flex items-center justify-center text-blue-600 mx-auto mb-4">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="4"></line><line x1="8" y1="2" x2="8" y2="4"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
    </div>
    
    <h2 class="text-gov-900 font-display font-bold text-xl mb-2">Exportação de Folha de Pagamentos</h2>
    <p class="text-slate-500 text-sm mb-6 max-w-md mx-auto">
      Gere a folha de pagamento contendo os dados bancários validados das cidadãs aptas para recebimento do Aluguel Social.
    </p>

    <div class="grid grid-cols-2 gap-4 max-w-sm mx-auto mb-8">
      <div class="bg-slate-50 border border-slate-100 rounded-lg p-4">
        <span class="text-xs text-slate-400 font-bold block mb-1">REQUERIMENTOS</span>
        <strong class="text-2xl text-gov-800"><%= aptos.length %></strong>
      </div>
      <div class="bg-slate-50 border border-slate-100 rounded-lg p-4">
        <span class="text-xs text-slate-400 font-bold block mb-1">TOTAL DA FOLHA</span>
        <strong class="text-lg text-gov-800">R$ <%= custoMensal.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong>
      </div>
    </div>

    <div class="flex justify-center gap-4">
      <button onclick="exportarDadosFinanceiros()" class="btn-action-primary" style="padding: 0.75rem 2rem; font-size: 0.95rem;">
        Exportar Planilha Financeira (CSV)
      </button>
    </div>
  </div>

  <!-- Tabela de Referência Oculta -->
  <table id="tabela-financeira-list" style="display: none;">
    <tbody>
      <% aptos.forEach(p => { 
        let bancoObj = { banco: 'N/A', agencia: 'N/A', conta: 'N/A' };
        try {
          if (p.beneficiaria.dadosBancariosManuais) {
            bancoObj = JSON.parse(p.beneficiaria.dadosBancariosManuais);
          }
        } catch(e){}
      %>
        <tr class="financeiro-row">
          <td><%= p.numeroProcessoSei %></td>
          <td><%= p.beneficiaria.nome %></td>
          <td><%= p.beneficiaria.cpf %></td>
          <td>Bco: <%= bancoObj.banco %> | Ag: <%= bancoObj.agencia %> | Cc: <%= bancoObj.conta %></td>
          <td><%= p.tipoEsteira %></td>
          <td>R$ <%= valorBase.toFixed(2) %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- ================= ABA 4: GESTÃO ORÇAMENTÁRIA ================= -->
<div id="tab-content-orcamento" class="tab-panel-content" style="display: none;">
  <!-- Acompanhamento Orçamentário Histórico (Ano a Ano, Mês a Mês) -->
  <div class="section-card" style="margin-top: 1rem; margin-bottom: 2rem;">
    <div class="section-header">
      <h2 class="section-title">Acompanhamento e Histórico Orçamentário (Ano a Ano)</h2>
    </div>
    <div class="section-content" style="padding: 0;">
      <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-color); background-color: var(--primary-light);">
        <p style="font-size: 0.85rem; color: var(--primary); line-height: 1.5; margin: 0; font-weight: 500;">
          📌 <strong>Lógica Recorrente Acumulada:</strong> Benefícios com status <em>APTO_PAGAMENTO</em> (Folha Ativa) continuam sendo pagos a cada mês de vigência ativo. Os meses futuros do ano corrente são projetados estimando a continuidade dessa folha.
        </p>
      </div>
      <div class="table-responsive">
        <table class="custom-table" id="tabela-historico-anos">
          <thead>
            <tr class="bg-slate-50 text-slate-500 font-semibold text-xs tracking-wider uppercase border-b border-slate-200">
              <th>Mês de Referência</th>
              <th class="text-right">Desembolso 2026 (Realizado / Proj)</th>
              <th class="text-right">Desembolso 2027 (Projetado)</th>
              <th class="text-right">Desembolso 2028 (Projetado)</th>
              <th class="text-right">Variação Anual (26 ➔ 27)</th>
            </tr>
          </thead>
          <tbody id="corpo-tabela-anos">
            <!-- Populado dinamicamente via JS -->
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- ================= ABA: ALERTAS DE RENOVAÇÃO ================= -->
<div id="tab-content-renovacao" class="tab-panel-content" style="display: none;">
  <div class="section-card" style="margin-top: 1rem; margin-bottom: 2rem;">
    <div class="section-header" style="background-color: #fff7ed; border-bottom: 1px solid #ffedd5;">
      <h2 class="section-title" style="color: #c2410c; margin: 0;">⚠️ Benefícios Expirando nos Próximos 60 Dias (Vencimento de Vigência)</h2>
    </div>
    <div class="section-content" style="padding: 0;">
      <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-color); background-color: #fffbeb;">
        <p style="font-size: 0.85rem; color: #b45309; line-height: 1.5; margin: 0; font-weight: 500;">
          💡 <strong>Ação Recomendada:</strong> Requerimentos ativos que estejam a menos de 60 dias de completarem 12 meses de recebimento contínuo devem ter seus processos de renovação ou descontinuidade iniciados pelos assistentes sociais do SUAS.
        </p>
      </div>
      <div class="table-responsive">
        <table class="custom-table" id="tabela-renovacao-list">
          <thead>
