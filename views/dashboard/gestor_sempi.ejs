        <div class="pagination-info" id="info-tabela-auditoria-list">
          Exibindo 0-0 de 0 processos
        </div>
        <div class="pagination-controls">
          <button class="pagination-btn" id="btn-prev-tabela-auditoria-list" onclick="pagAuditoriaAnt()">Ant.</button>
          <button class="pagination-btn" id="btn-next-tabela-auditoria-list" onclick="pagAuditoriaProx()">Próx.</button>
        </div>
      </div>
    </div>
  </div>
</div>

