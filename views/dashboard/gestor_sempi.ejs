      </div>

      <!-- Dados Bancários -->
      <div class="drawer-section">
        <div class="drawer-section-title">Dados para Pagamento</div>
        <div class="bank-card-mockup" style="background: linear-gradient(135deg, var(--primary), var(--primary-hover));">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <div class="bank-card-chip"></div>
            <div class="bank-card-brand">Aluguel Social</div>
          </div>
          <div class="bank-card-number" style="font-size: 1.15rem;">
            AG: ${dadosBancarios.agencia} | CC: ${dadosBancarios.conta}
          </div>
          <div class="bank-card-row">
            <div>
              <div class="bank-card-label">Favorecida</div>
              <div class="bank-card-holder">${p.beneficiaria.nome}</div>
            </div>
            <div style="text-align: right;">
              <div class="bank-card-label">Banco</div>
