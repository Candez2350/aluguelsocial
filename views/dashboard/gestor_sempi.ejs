            <span class="drawer-label">CPF</span>
            <div class="confidential-wrapper">
              <span class="confidential-data blurred" style="font-family: monospace;">${p.beneficiaria.cpf}</span>
              <button class="btn-toggle-sigilo" onclick="toggleSigilo(this)" style="font-size: 0.75rem; padding: 2px 4px;">Exibir</button>
            </div>
          </div>
          <div class="drawer-item">
            <span class="drawer-label">NIS CadÚnico</span>
            <span class="drawer-value">${p.beneficiaria.nisCadunico}</span>
