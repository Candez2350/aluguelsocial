{
  "name": "aluguel-social",
  "version": "1.0.0",
  "description": "Sistema de Auxilio Aluguel - MVP Modular",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.css",
    "dev:css": "tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.css --watch",
    "vercel-build": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
